     <td colspan=\"5\">\r\n                <input name=\"ctl00$Main$CustomerEditGeneral$tbProductDiscount\" type=\"text\" value=\"30.0\" maxlength=\"5\" readonly=\"readonly\" id=\"Main_CustomerEditGeneral_tbProductDiscount\" style=\"width:50px;\" /><span id=\"Main_CustomerEditGeneral_vldProductDiscount\" class=\"validator\" style=\"display:none;\">Product discount is required.</span><span id=\"Main_CustomerEditGeneral_vldProductDiscount2\" class=\"validator\" style=\"display:none;\">Discount must be between 0 and 100.</span>\r\n            </td>\r\n        </tr>\r\n        <tr>\r\n            <td class=\"s\">Hosting discount (%)<span class=\"required\">*</span></td>\r\n            <td colspan=\"5\">\r\n                <input name=\"ctl00$Main$CustomerEditGeneral$tbHostingDiscount\" type=\"text\" value=\"20.0\" maxlength=\"5\" id=\"Main_CustomerEditGeneral_tbHostingDiscount\" style=\"width:50px;\" /><span id=\"Main_CustomerEditGeneral_vldHostingDiscount\" class=\"validator\" style=\"display:none;\">Hosting discount is required.</span><span id=\"Main_CustomerEditGeneral_vldHostingDiscount2\" class=\"validator\" style=\"display:none;\">Hosting discount must be between 0 and 100.</span>\r\n            </td>\r\n        </tr>\r\n        <tr>\r\n            <td class=\"s\">Maintenance discount (%)<span class=\"required\">*</span></td>\r\n            <td colspan=\"5\">\r\n                <input name=\"ctl00$Main$CustomerEditGeneral$tbMaintenanceDiscount\" type=\"text\" value=\"30.0\" maxlength=\"5\" readonly=\"readonly\" id=\"Main_CustomerEditGeneral_tbMaintenanceDiscount\" style=\"width:50px;\" /><span id=\"Main_CustomerEditGeneral_vldMaintenanceDiscount\" class=\"validator\" style=\"display:none;\">Maintenance discount is required.</span><span id=\"Main_CustomerEditGeneral_vldMaintenanceDiscount2\" class=\"validator\" style=\"display:none;\">Discount must be between 0 and 100.</span>\r\n            </td>\r\n        </tr>\r\n    \r\n\r\n    <tr>\r\n        <td class=\"s\">Enabled</td>\r\n        <td colspan=\"4\">\r\n            <table style=\"width: 300px; white-space: normal\">\r\n                <tr>\r\n                    <td style=\"margin-right: 1em\">\r\n                        <input id=\"Main_CustomerEditGeneral_cbEnabled\" type=\"checkbox\" name=\"ctl00$Main$CustomerEditGeneral$cbEnabled\" checked=\"checked\" /></td>\r\n                    <td id=\"Main_CustomerEditGeneral_DisableWarning\" style=\"border: 1px dashed #c0c0c0; padding: 0.2em; white-space: normal\"><span>WARNING: Disabling an account will auto-reallocate any assigned leads.</span></td>\r\n\t\t\t\r\n                </tr>\r\n            </table>\r\n        </td>\r\n    </tr>\r\n\r\n    \r\n        <tr>\r\n            \r\n                <td class=\"s\">List on 3CX Website</td>\r\n                <td>\r\n                    <input id=\"Main_CustomerEditGeneral_cbShowOnWebsite\" type=\"checkbox\" name=\"ctl00$Main$CustomerEditGeneral$cbShowOnWebsite\" checked=\"checked\" /></td>\r\n            \r\n        </tr>\r\n    \r\n\r\n    \r\n        <tr>\r\n            <td class=\"s\">High Potential</td>\r\n            <td>\r\n                <input id=\"Main_CustomerEditGeneral_cbHighPotential\" type=\"checkbox\" name=\"ctl00$Main$CustomerEditGeneral$cbHighPotential\" /></td>\r\n        </tr>\r\n    \r\n\r\n    \r\n\r\n    \r\n        <tr>\r\n            <td class=\"s\">Not Committed Partner</td>\r\n            <td>\r\n                <input id=\"Main_CustomerEditGeneral_cbNotCommited\" type=\"checkbox\" name=\"ctl00$Main$CustomerEditGeneral$cbNotCommited\" /></td>\r\n        </tr>\r\n    \r\n\r\n    <tr>\r\n        <td class=\"s\">Start Date</td>\r\n        <td>\r\n            <span id=\"Main_CustomerEditGeneral_lblStartDate\" style=\"font-weight:bold;\">08/04/16</span>\r\n        </td>\r\n    </tr>\r\n\r\n    <tr>\r\n        <td class=\"s\">Sales Rep</td>\r\n        <td>\r\n            <span id=\"Main_CustomerEditGeneral_lblSalesRep\" style=\"font-weight:bold;\">Petros Chatziioannidis</span>\r\n        </td>\r\n    </tr>\r\n\r\n    <tr>\r\n        <td class=\"s\" colspan=\"2\">\r\n            <h3>Partner Profiling</h3>\r\n        </td>\r\n    </tr>\r\n    <tr>\r\n        <td class=\"s\">Category</td>\r\n        <td>\r\n            <select name=\"ctl00$Main$CustomerEditGeneral$ddlPartnerCategories\" id=\"Main_CustomerEditGeneral_ddlPartnerCategories\">\r\n\t\t\t\t<option value=\"1\">MSP</option>\r\n\t\t\t\t<option selected=\"selected\" value=\"2\">System Integrator</option>\r\n\t\t\t\t<option value=\"4\">VoIP Provider</option>\r\n\t\t\t\t<option value=\"6\">Telecom Reseller</option>\r\n\t\t\t\t<option value=\"7\">Consultant</option>\r\n\t\t\t\t<option value=\"8\">Other</option>\r\n\r\n\t\t\t</select></td>\r\n    </tr>\r\n    <tr>\r\n        <td class=\"s\">How do you predominantly sell 3CX</td>\r\n        <td>\r\n            <select name=\"ctl00$Main$CustomerEditGeneral$ddlPartnerSellOptions\" id=\"Main_CustomerEditGeneral_ddlPartnerSellOptions\">\r\n\t\t\t\t<option value=\"1\">Per user per month complete package</option>\r\n\t\t\t\t<option value=\"2\">Installation only</option>\r\n\t\t\t\t<option selected=\"selected\" value=\"3\">Installation and monthly per install support</option>\r\n\t\t\t\t<option value=\"4\">Bundled with MSP services</option>\r\n\r\n\t\t\t</select></td>\r\n    </tr>\r\n    <tr>\r\n        <td class=\"s\">Do you require a particular VoIP\r\n            <br />\r\n            provider to be used with 3CX</td>\r\n        <td>\r\n            <select name=\"ctl00$Main$CustomerEditGeneral$ddlPartnerSipTrunkOption\" id=\"Main_CustomerEditGeneral_ddlPartnerSipTrunkOption\">\r\n\t\t\t\t<option selected=\"selected\" value=\"\"></option>\r\n\t\t\t\t<option value=\"1\">My own service</option>\r\n\t\t\t\t<option value=\"2\">Rebranded service</option>\r\n\t\t\t\t<option value=\"3\">Other</option>\r\n\t\t\t\t<option value=\"1073741826\" data-category=\"Known VoIP Providers\">1CX</option>\r\n\t\t\t\t<option value=\"107374182