            "mimeType": "application/javascript",
            "text": "function SelectAllCheckBoxes(theBox, gvSelected)\r\n{\r\n    var xState=theBox.checked;\r\n    var elm=theBox.form.elements;\r\n    var strElmID;\r\n\r\n    for(var i=0;i<elm.length;i++)\r\n    {\r\n        strElmID = elm[i].id;\r\n        if(elm[i].type==\"checkbox\" && strElmID!=theBox.id && strElmID.indexOf(gvSelected)!=-1 )\r\n        {\r\n            if(elm[i].checked!=xState)\r\n            {\r\n                elm[i].click();\r\n            }\r\n        }\r\n    }\r\n}\r\n\r\n\r\nfunction ClearAllCheckBoxes(elem) {\r\n    var xState = false;\r\n    var elm = elem.closest('form').elements;\r\n    var strElmID;\r\n\r\n    for (var i = 0; i < elm.length; i++) {\r\n        strElmID = elm[i].id;\r\n        if (elm[i].type == \"checkbox\" && strElmID != 'chkAll' && strElmID.indexOf('chkSelect') != -1) {\r\n            if (elm[i].checked != xState) {\r\n                elm[i].click();\r\n            }\r\n        }\r\n    }\r\n}\r\n\r\nvar chkSelected=0;\r\n\r\nfunction HighlightRow(elem, buttons1, buttons2) {\r\n    var tr = elem.closest('tr');\r\n    var selected = $(tr).attr('highlighted');\r\n    if (selected != 'true' && (elem.checked == undefined || elem.checked == true))\r\n    {\r\n        tr.style.backgroundColor = \"#CADDEE\";\r\n        tr.setAttribute('highlighted', true);\r\n        chkSelected++;\r\n    }\r\n    else\r\n    {\r\n        tr.style.backgroundColor = \"\"; \r\n        tr.setAttribute('highlighted', false);\r\n        chkSelected--;\r\n        if(chkSelected < 0) chkSelected = 0;\r\n    }\r\n    \r\n    UpdateButtons(buttons1,buttons2);\r\n}\r\n\r\nfunction HighlightRow2(chkB, buttons1, buttons2) {\r\n    if (chkB.checked && chkB.parentNode && chkB.parentNode.parentNode && chkB.parentNode.parentNode.parentNode) {\r\n        chkB.parentNode.parentNode.parentNode.style.backgroundColor = \"#CADDEE\";\r\n        chkSelected++;\r\n    }\r\n    else if (chkB.parentNode && chkB.parentNode.parentNode && chkB.parentNode.parentNode.parentNode) {\r\n        chkB.parentNode.parentNode.parentNode.style.backgroundColor = \"\";\r\n        chkSelected--;\r\n        if (chkSelected < 0) chkSelected = 0;\r\n    }\r\n\r\n    UpdateButtons(buttons1, buttons2);\r\n}\r\n\r\nfunction UpdateButtons(buttons1, buttons2)\r\n{\r\n    if(buttons1)\r\n        for(var i=0;i<buttons1.length;i++)\r\n            if(buttons1[i]) \r\n                buttons1[i].disabled = chkSelected == 0;\r\n\r\n    if(buttons2)\r\n        for(var i=0;i<buttons2.length;i++)\r\n            if(buttons2[i])\r\n                buttons2[i].disabled = chkSelected != 1;\r\n}\r\n\r\nfunction GetSelectedCount(form,gvSelected)\r\n{\r\n    var elm=form.elements;\r\n    var count=0;\r\n\r\n    for(var i=0;i<elm.length;i++)\r\n    {\r\n        var strElmID = elm[i].id;\r\n        if(elm[i].type==\"checkbox\" && strElmID.indexOf(gvSelected)!=-1 && elm[i].checked) count++;\r\n    }\r\n    \r\n    return count;\r\n}\r\n\r\nfunction HighlightSelectedRows2(form, gvSelected) {\r\n    var elm = form.elements;\r\n    var count = 0;\r\n\r\n    for (i = 0; i < elm.length; i++) {\r\n        var strElmID = elm[i].id;\r\n        if (elm[i].type == \"checkbox\" && strElmID.indexOf(gvSelected) != -1 && elm[i].checked) {\r\n            var chkB = elm[i];\r\n            if (chkB.checked && chkB.parentNode && chkB.parentNode.parentNode && chkB.parentNode.parentNode.parentNode) {\r\n                chkB.parentNode.parentNode.parentNode.style.backgroundColor = \"#CADDEE\";\r\n                chkSelected++;\r\n            }\r\n            else if (chkB.parentNode && chkB.parentNode.parentNode && chkB.parentNode.parentNode.parentNode) {\r\n                chkB.parentNode.parentNode.parentNode.style.backgroundColor = \"\";\r\n                chkSelected--;\r\n                if (chkSelected < 0) chkSelected = 0;\r\n            }\r\n        }\r\n    }\r\n}\r\n\r\nMyDataGrid = function MyDataGridFunc() {\r\n    var selected;\r\n    function SelectedIndexChanged(url) {\r\n        if (selected !== this) {\r\n            $(selected).removeClass('st-selected');\r\n            selected = this;\r\n        }\r\n        $(this).toggleClass('st-selected');\r\n        window.open(url, '_self');\r\n    }\r\n\r\n    var previousSearchText;\r\n    function DoSearch(event, sender) {\r\n        if (sender.value && (0 < sender.value.length && sender.value.length < 3))\r\n            return;\r\n        if (previousSearchText != sender.value) {\r\n            previousSearchText = sender.value;\r\n            __doPostBack('tbSearch', sender.value + ';' + sender.selectionStart);\r\n        }\r\n    }\r\n\r\n    return {\r\n        SelectedIndexChanged: SelectedIndexChanged,\r\n        DoSearch: DoSearch\r\n    };\r\n}();\r\n\r\n\r\njQuery(document).ready(function ($) {\r\n    function SetSearchFocus() {\r\n        var obj = $('#tbSearch');\r\n        if (!obj || obj.length == 0) return;\r\n        var val = obj.val() | '';\r\n        var length = val.length * 2;\r\n        obj.focus();\r\n\r\n        var pos = $('#tbSearchCaretPosition').val();\r\n        if (!pos)\r\n            pos = length;\r\n        obj[0].setSelectionRange(pos, pos);\r\n    }\r\n    SetSearchFocus();\r\n    if (typeof (Sys) != \"undefined\") {\r\n\r\n        Sys.WebForms.PageRequestManager.getInstance().add_pageLoaded(function () {\r\n            SetSearchFocus();\r\n        });\r\n    }\r\n});"
