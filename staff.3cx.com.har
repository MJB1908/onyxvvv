            "text": "function bindEvents($) {\r\n    $('input[type=checkbox].toggleCheckbox').click(function() {\r\n        var checked = $(this).is(\":checked\");\r\n        var $form = $(this).closest(\"form\");\r\n        if ($form.length > 0) {\r\n            var $checkboxes = $(\"input[type=checkbox]\", $form);\r\n            $checkboxes.prop(\"checked\", checked);\r\n            $checkboxes.closest(\"tr\").css(\"backgroundColor\", checked ? \"Wheat\" : \"\");\r\n            if (checked) {\r\n                $(\".removeButton\", $form).removeAttr(\"disabled\");\r\n            } else {\r\n                $(\".removeButton\", $form).attr(\"disabled\", \"disabled\");\r\n            }\r\n        }\r\n    });\r\n    $('input[type=checkbox].selection').click(function() {\r\n        var checked = $(this).is(\":checked\");\r\n        var $row = $(this).closest(\"tr\");\r\n        $row.css(\"backgroundColor\", checked ? \"Wheat\" : \"\");\r\n        // check/uncheck all subitems\r\n        $row.nextAll().each(function () {\r\n            var $checkboxes = $(\"input[type=checkbox].selectionSub\", $(this));\r\n            if ($checkboxes.length == 0) return false;\r\n            $checkboxes.prop(\"checked\", checked).closest(\"tr\").css(\"backgroundColor\", checked ? \"Wheat\" : \"\");\r\n            return true;\r\n        });\r\n        if (!checked && $(this).hasClass(\"selectionSub\")) {\r\n            // switch off the parent elements and its subrows\r\n            $row.prevAll().each(function () {\r\n                var $checkboxes = $(\"input[type=checkbox].selectionSub\", $(this));\r\n                if ($checkboxes.length > 0) return true;\r\n                // we found the parent element\r\n                $checkboxes = $(\"input[type=checkbox].selection\", $(this));\r\n                $checkboxes.prop(\"checked\", false);\r\n                $(this).css(\"backgroundColor\", checked ? \"Wheat\" : \"\");\r\n                // check all sub elements\r\n                $(this).nextAll().each(function () {\r\n                    $checkboxes = $(\"input[type=checkbox].selectionSub\", $(this));\r\n                    if ($checkboxes.length == 0) return false;\r\n                    $checkboxes.prop(\"checked\", checked).closest(\"tr\").css(\"backgroundColor\", checked ? \"Wheat\" : \"\");\r\n                    return true;\r\n                });\r\n                return false; // stop the loop\r\n            });\r\n        }\r\n        var $form = $(this).closest(\"form\");\r\n        if ($form.length > 0) {\r\n            var enabled = false;\r\n            $(\"input[type=checkbox].selection\").each(function() {\r\n                if ($(this).is(\":checked\")) {\r\n                    enabled = true;\r\n                    return false;\r\n                }\r\n                return true;\r\n            });\r\n            if (enabled) {\r\n                $(\".removeButton\", $form).removeAttr(\"disabled\");\r\n            } else {\r\n                $(\".removeButton\", $form).attr(\"disabled\", \"disabled\");\r\n            }\r\n        }\r\n    });\r\n    \r\n    $(\".removeButton\").attr(\"disabled\", \"disabled\");\r\n}\r\njQuery(document).ready(function($) {\r\n    bindEvents($);\r\n    Sys.WebForms.PageRequestManager.getInstance().add_pageLoaded(function() { bindEvents($); });\r\n});\r\n"
