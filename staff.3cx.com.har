            "text": "body {\r\n    margin:0;\r\n    font-family:arial,helvetica,sans;\r\n    font-size: 10pt;\r\n    background: #fff;\r\n    margin: 0;\r\n    color: #000;\r\n    margin-bottom: 2em;\r\n}\r\np {\r\n    line-height: 1.4em;\r\n}\r\nh1\r\n{\r\n  font-size: 11pt;\r\n}\r\nh2\r\n{\r\n  font-size: 10pt;\r\n}\r\na, a:visited\r\n{\r\n  color:#007BC7;\r\n  text-decoration:none;\r\n}\r\na:hover\r\n{\r\n  text-decoration:underline;\r\n}\r\n.portal_header {\r\n    width: 100%;\r\n    border-collapse: collapse;\r\n    padding: 0;\r\n    margin: 0;\r\n    background: #333;\r\n    height: 70px;\r\n}\r\n.portal_header td {\r\n    height: 70px;\r\n    margin: 0;\r\n    padding: 0;\r\n}\r\n.portal_header td.skydiver div {\r\n    text-align: right;\r\n    height: 70px;\r\n}\r\n.portal_header td.threecxlogo {\r\n    padding-right: 32px;\r\n}\r\n.portal_header td.wide {\r\n    width: 100%;\r\n}\r\n#panel .tabs {\r\n    font-size: 10pt;\r\n}\r\nselect {\r\n    font-size: 10pt;\r\n}\r\ntable.report tr td {\r\n    font-size: 9pt;\r\n}\r\n#panel table.datagrid tr.header td, \r\n#cart table.datagrid tr.header td, \r\n#panel table.datagrid tr th, \r\n#cart table.datagrid tr th {\r\n    font-size: 10pt;\r\n    font-weight: bold;\r\n    white-space: nowrap;\r\n}"
