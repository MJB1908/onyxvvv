          "content": {
            "size": 169838,
            "mimeType": "text/html",
            "text": "\r\n\r\n<!DOCTYPE html>\r\n\r\n<html lang=\"en-EN\">\r\n<head id=\"Head1\"><title>\r\n\t3CX Network - Administration Area\r\n</title><meta http-equiv=\"Content-Type\" content=\"text/html; charset=utf-8\" /><link rel=\"shortcut icon\" href=\"https://www.3cx.com/wp-content/themes/MDM/favicon.ico\" /><link rel=\"stylesheet\" type=\"text/css\" href=\"/css/print.css?ver=1.8\" media=\"print\" /><link rel=\"stylesheet\" type=\"text/css\" href=\"/css/popup.css?ver=1.7\" /><link rel=\"stylesheet\" type=\"text/css\" href=\"/content/3cx/portal/styles.css\" /><link rel=\"stylesheet\" type=\"text/css\" href=\"/css/webinars.css?ver=1.1\" /><link rel=\"stylesheet\" type=\"text/css\" href=\"/content/bootstrap.min.css?ver=5.3.7\" /><link rel=\"stylesheet\" type=\"text/css\" href=\"/css/styles.css?ver=1.56\" /><link rel=\"stylesheet\" type=\"text/css\" href=\"/css/font.css\" /><link rel=\"stylesheet\" type=\"text/css\" href=\"/content/font-awesome.css\" /><link rel=\"stylesheet\" type=\"text/css\" href=\"/content/simple-line-icons.css\" />\r\n    <script type=\"text/javascript\" src=\"/scripts/jquery-3.7.1.min.js\"></script>\r\n    <script type=\"text/javascript\" src=\"/scripts/popup.js?ver=1.9\"></script>\r\n    <script type=\"text/javascript\" src=\"/scripts/datagrid.js?ver=1.53\"></script>\r\n    <script type=\"text/javascript\" src=\"/scripts/checkboxes.js?ver=1.1\"></script>\r\n    <script type=\"text/javascript\" src=\"/scripts/bootstrap.min.js?ver=5.3.7\"></script>\r\n    <script type=\"text/javascript\" src=\"/scripts/moment.min.js?ver=2.29.4\"></script>\r\n    <script type=\"text/javascript\" src=\"/scripts/moment-timezone.min.js?ver=0.5.43\"></script>\r\n    <script type=\"text/javascript\" src=\"/pagescripts/dashboard.js?ver=1.11\"></script>\r\n\r\n    \r\n    <style type=\"text/css\">\r\n        #contents, .mycontent {\r\n            max-width: 1025px;\r\n            margin: 10px;\r\n            position: fixed;\r\n            bottom: 0;\r\n        }\r\n\r\n            .mycontent a {\r\n                text-decoration: none;\r\n            }\r\n\r\n            #contents, #contents td, #contents th,\r\n            .mycontent, .mycontent td, .mycontent th,\r\n            #top_navigation {\r\n                font-family: Arial,Helvetica,sans-serif;\r\n                font-size: 15px;\r\n            }\r\n\r\n        #top_header {\r\n            background-color: #363636;\r\n            height: 55px;\r\n            position: relative;\r\n        }\r\n\r\n        #logo {\r\n            position: absolute;\r\n            top: 5px;\r\n            left: 10px;\r\n            width: 100px;\r\n        }\r\n\r\n        #partner_portal {\r\n            position: absolute;\r\n            bottom: 0;\r\n            right: 0;\r\n        }\r\n\r\n            #partner_portal img {\r\n                width: 100%;\r\n            }\r\n\r\n        #top_navigation {\r\n            position: absolute;\r\n            bottom: 10px;\r\n            left: 100px;\r\n            color: #FFF;\r\n            width: auto;\r\n        }\r\n\r\n            #top_navigation ul, #top_navigation ul li {\r\n                list-style: none;\r\n                padding-left: 10px;\r\n            }\r\n\r\n                #top_navigation ul li {\r\n                    float: left;\r\n                    padding-left: 15px;\r\n                    padding-right: 15px;\r\n                    padding-bottom: 0;\r\n                    background-image: url('/content/shared/images/menu-separator.jpg');\r\n                    background-position: left bottom;\r\n                    background-repeat: no-repeat;\r\n                }\r\n\r\n                    #top_navigation ul li:first-child {\r\n                        background: none;\r\n                        padding-left: 0;\r\n                    }\r\n\r\n                    #top_navigation ul li a {\r\n                        color: #CCC;\r\n                        text-decoration: none;\r\n                        font-weight: 400;\r\n                        font-size: 14px;\r\n                    }\r\n\r\n        #contents h2, .mycontent h2 {\r\n            color: #888888;\r\n            font-size: 20px;\r\n            font-weight: bold;\r\n            margin-bottom: 4px;\r\n        }\r\n\r\n        .algnleft {\r\n            float: left;\r\n            margin-bottom: 8px;\r\n            margin-right: 8px;\r\n            border-radius: 3px;\r\n            -moz-border-radius: 3px;\r\n            -webkit-border-radius: 3px;\r\n            position: relative;\r\n        }\r\n\r\n        .center {\r\n            text-align: center;\r\n        }\r\n\r\n        .box {\r\n            width: 110px;\r\n            height: 110px;\r\n            display: block;\r\n            color: #FFF;\r\n            position: relative;\r\n        }\r\n\r\n        .green_box {\r\n            background-color: #019c10;\r\n        }\r\n\r\n        .blue_box {\r\n            background-color: #0596d4;\r\n        }\r\n\r\n        .red_box {\r\n            background-color: #9e0b0f;\r\n        }\r\n\r\n        .grey_box {\r\n            background-color: #696969;\r\n        }\r\n\r\n        .light_grey_box {\r\n            background-color: #b3b3b3;\r\n        }\r\n\r\n        .amber_box {\r\n            background-color: #CE9400;\r\n        }\r\n\r\n        .mainmessage {\r\n            font-size: 20px;\r\n            position: relative;\r\n            top: 45%;\r\n            -ms-transform: translateY(-45%);\r\n            -webkit-transform: translateY(-45%);\r\n            -moz-transform: translateY(-45%);\r\n            -o-transform: translateY(-45%);\r\n            transform: translateY(-45%);\r\n            font-weight: 600;\r\n        }\r\n\r\n        .largefont .mainmessage {\r\n            font-size: 40px;\r\n        }\r\n\r\n        .submessage {\r\n            font-size: 13px;\r\n            font-weight: bold;\r\n            color: #FFF;\r\n            position: absolute;\r\n            bottom: 16%;\r\n            width: 100%;\r\n            line-height: 13px;\r\n            -ms-transform: translateY(50%);\r\n            -webkit-transform: translateY(50%);\r\n            -moz-transform: translateY(50%);\r\n            -o-transform: translateY(50%);\r\n            transform: translateY(50%);\r\n        }\r\n\r\n        .icon {\r\n            margin-top: 19px;\r\n        }\r\n\r\n        .iconp {\r\n            margin-top: -5px;\r\n        }\r\n\r\n        #my_performance, #my_tools, #my_tools_acx {\r\n            display: block;\r\n            clear: both;\r\n            position: relative;\r\n            margin-bottom: 5px;\r\n        }\r\n\r\n        .clear {\r\n            clear: both;\r\n        }\r\n\r\n        #upcoming a {\r\n            color: #0596d4;\r\n            display: block;\r\n            line-height: 30px;\r\n            font-size: 14px;\r\n        }\r\n\r\n        .quarter_points {\r\n            position: absolute;\r\n            top: 5px;\r\n            left: 0;\r\n            font-size: 35px;\r\n            text-align: right !important;\r\n            width: 52px;\r\n        }\r\n\r\n        .quarter_points_of {\r\n            position: absolute;\r\n            bottom: 32px;\r\n            right: 0;\r\n            font-size: 35px;\r\n            text-align: left !important;\r\n            width: 52px;\r\n        }\r\n\r\n        #top_header .viewas {\r\n            margin: 1px;\r\n        }\r\n\r\n        #feeds a {\r\n            color: #000;\r\n            text-decoration: underline;\r\n        }\r\n\r\n        #support a, #sales a {\r\n            color: #363636;\r\n            font-weight: normal;\r\n            text-decoration: underline\r\n        }\r\n\r\n        @media screen and (max-width: 1870px) {\r\n            img#partner_portal {\r\n                position: relative;\r\n                float: right;\r\n            }\r\n        }\r\n    </style>\r\n</head>\r\n<body>\r\n    <div id=\"popupbg\" style=\"display: n