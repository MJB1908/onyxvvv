          "content": {
            "size": 126539,
            "mimeType": "text/plain",
            "text": "1|#||4|32|updatePanel|Main_MessageBoxUpdatePanel|\r\n                \r\n            |74932|updatePanel|Main_CustomerEditUpdatePanel|\r\n                <div id=\"Main_pnlCustomerEdit\" class=\"editcust\" onkeypress=\"javascript:return WebForm_FireDefaultButton(event, &#39;Main_btnSaveExit&#39;)\">\r\n\t\r\n\r\n                    \r\n\r\n                    <h3>\r\n                        Edit Partner '.incotech GmbH'</h3>\r\n\r\n                    <div id=\"Main_plhTabs\" class=\"custtabs\">\r\n\t\t\r\n                        <a id=\"Main_btnProperties\" class=\"tab-link\" href=\"javascript:__doPostBack(&#39;ctl00$Main$btnProperties&#39;,&#39;&#39;)\">General</a>\r\n                        | \r\n                    <a id=\"Main_btnUsers\" class=\"tab-link\" href=\"javascript:__doPostBack(&#39;ctl00$Main$btnUsers&#39;,&#39;&#39;)\">Users</a>\r\n                        |\r\n                    <a id=\"Main_btnBilling\" class=\"tab-link\" href=\"javascript:__doPostBack(&#39;ctl00$Main$btnBilling&#39;,&#39;&#39;)\">Account & Billing</a>\r\n                        \r\n                        |\r\n                        <a id=\"Main_btnNotes\" class=\"tab-link\" href=\"javascript:__doPostBack(&#39;ctl00$Main$btnNotes&#39;,&#39;&#39;)\">Notes</a>|\r\n                                <a id=\"Main_btnAdditionalListings\" class=\"tab-link\" href=\"javascript:__doPostBack(&#39;ctl00$Main$btnAdditionalListings&#39;,&#39;&#39;)\">Additional Listings</a>\r\n                            |\r\n                            <a id=\"Main_btnCertification\" class=\"tab-link\" href=\"javascript:__doPostBack(&#39;ctl00$Main$btnCertification&#39;,&#39;&#39;)\">Certification</a>\r\n\r\n                        |\r\n                                <a id=\"Main_btnLeads\" href=\"javascript:__doPostBack(&#39;ctl00$Main$btnLeads&#39;,&#39;&#39;)\">Leads</a>|\r\n                                <a id=\"Main_btnPerformance\" href=\"javascript:__doPostBack(&#39;ctl00$Main$btnPerformance&#39;,&#39;&#39;)\">Performance</a>|\r\n                                <a id=\"Main_btnOrders\" href=\"javascript:__doPostBack(&#39;ctl00$Main$btnOrders&#39;,&#39;&#39;)\">Orders</a>|\r\n                                <a id=\"Main_btnKeys\" href=\"javascript:__doPostBack(&#39;ctl00$Main$btnKeys&#39;,&#39;&#39;)\">Keys</a>\r\n\r\n                        |\r\n                            <a id=\"Main_hlFreshdeskTickets\" CausesValidation=\"false\" href=\"https://helpdesk.3cx.com/companies/9000584805\" target=\"_blank\">Tickets</a>\r\n\r\n                        |\r\n                            <a id=\"Main_btnPoints\" class=\"tab-link\" href=\"javascript:__doPostBack(&#39;ctl00$Main$btnPoints&#39;,&#39;&#39;)\">Revenue</a>\r\n\r\n                        |\r\n                            <a id=\"Main_btnStatistics\" class=\"tab-link tab-link-active\" href=\"javascript:__doPostBack(&#39;ctl00$Main$btnStatistics&#39;,&#39;&#39;)\">Statistics</a>\r\n                    \r\n\t</div>\r\n\r\n                    \r\n\r\n                    \r\n\r\n                    <div id=\"Main_pnlBilling\" class=\"tab-panel hidden hidden hidden\">\r\n\t\t\r\n                        <table class=\"cols\">\r\n                            <tr>\r\n                                <td>\r\n                                    <div style=\"margin-right: 50px\">\r\n                                        \r\n\r\n<h3>Contact Information (Public)</h3>\r\n<table class=\"c\">\r\n    <tr>\r\n        <td class=\"s\">Company<span class=\"required\">*</span></td>\r\n        <td>\r\n            <input name=\"ctl00$Main$CustomerEditContact$tbCompany\" type=\"text\" value=\".incotech GmbH\" maxlength=\"50\" id=\"Main_CustomerEditContact_tbCompany\" style=\"width:300px;\" />\r\n            <span id=\"Main_CustomerEditContact_vldCompany\" class=\"validator\" style=\"display:none;\">Company required</span>\r\n        </td>\r\n    </tr>\r\n    <tr>\r\n        <td class=\"s\">Contact First Name<span class=\"required\">*</span></td>\r\n        <td>\r\n            <input name=\"ctl00$Main$CustomerEditContact$tbContactFirstName\" type=\"text\" value=\"Jens\" maxlength=\"24\" id=\"Main_CustomerEditContact_tbContactFirstName\" style=\"width:300px;\" />\r\n            <span id=\"Main_CustomerEditContact_vldFirstName\" class=\"validator\" style=\"display:none;\">Contact First Name required.</span>\r\n        </td>\r\n    </tr>\r\n    <tr>\r\n        <td class=\"s\">Contact Last Name<span class=\"required\">*</span></td>\r\n        <td>\r\n            <input name=\"ctl00$Main$CustomerEditContact$tbContactLastName\" type=\"text\" value=\"Burgath\" maxlength=\"25\" id=\"Main_CustomerEditContact_tbContactLastName\" style=\"width:300px;\" />\r\n            <span id=\"Main_CustomerEditContact_vldLastName\" class=\"validator\" style=\"display:none;\">Contact Last Name required.</span>\r\n        </td>\r\n    </tr>\r\n    <tr>\r\n        <td class=\"s\">Email Address<span class=\"required\">*</span></td>\r\n        <td>\r\n            <input name=\"ctl00$Main$CustomerEditContact$tbEmail\" type=\"text\" value=\"service@incotech.de\" maxlength=\"50\" id=\"Main_CustomerEditContact_tbEmail\" autocomplete=\"off\" style=\"width:300px;\" />\r\n            <span id=\"Main_CustomerEditContact_vldEmail\" class=\"validator\" style=\"display:none;\">Email required</span>\r\n            <span id=\"Main_CustomerEditContact_vldEmail2\" class=\"validator\" style=\"display:none;\">Malformed email address.</span>\r\n            <span id=\"Main_CustomerEditContact_EmailDomainValidator\" class=\"validator\" style=\"display:none;\">Email cannot be in @3cx.com domain.</span>\r\n        </td>\r\n    </tr>\r\n    <tr>\r\n        <td class=\"s\">Telephone\r\n        </td>\r\n        <td>\r\n            <input name=\"ctl00$Main$CustomerEditContact$tbPhone\" type=\"text\" value=\"+49 5601 961990\" maxlength=\"20\" id=\"Main_CustomerEditContact_tbPhone\" style=\"width:300px;\" />\r\n            <span id=\"Main_CustomerEditContact_vldTelephone\" class=\"validator\" style=\"display:none;\">Telephone required.</span>\r\n        </td>\r\n    </tr>\r\n    <tr>\r\n        <td class=\"s\">Fax</td>\r\n        <td>\r\n            <input name=\"ctl00$Main$CustomerEditContact$tbFax\" type=\"text\" value=\"+49 5601 9619925\" maxlength=\"20\" id=\"Main_CustomerEditContact_tbFax\" style=\"width:300px;\" />\r\n        </td>\r\n    </tr>\r\n    <tr>\r\n        <td class=\"s\">Website URL</td>\r\n        <td>\r\n            <input name=\"ctl00$Main$CustomerEditContact$tbURL\" type=\"text\" value=\"http://www.incotech.de\" maxlength=\"200\" id=\"Main_CustomerEditContact_tbURL\" style=\"width:280px;\" /><input type=\"image\" name=\"ctl00$Main$CustomerEditContact$btnWebsite\" id=\"Main_CustomerEditContact_btnWebsite\" src=\"/content/shared/images/play.gif\" align=\"top\" onclick=\"return VisitWebsite();\" /><br />\r\n            <span id=\"Main_CustomerEditContact_vldURL\" class=\"validator\" style=\"display:none;\">Malformed Website URL</span></td>\r\n    </tr>\r\n    <tr>\r\n        <td class=\"s\">Click To Call URL</td>\r\n        <td>\r\n            <input name=\"ctl00$Main$CustomerEditContact$tbClickToCall\" type=\"text\" maxlength=\"200\" id=\"Main_CustomerEditContact_tbClickToCall\" placeholder=\"https://{FQDN}:{PORT}/{NAME}\" style=\"width:280px;\" /><input type=\"image\" name=\"ctl00$Main$CustomerEditContact$ImageButton1\" id=\"Main_CustomerEditContact_ImageButton1\" src=\"/content/shared/images/play.gif\" align=\"top\" onclick=\"return VisitClickToCall();\" /><br />\r\n            <span id=\"Main_CustomerEditContact_vldClickToCall\" class=\"validator\" style=\"display:none;\">Malformed Click To Call URL</span>\r\n        </td>\r\n    </tr>\r\n</table>\r\n\r\n                                        <div id=\"Main_CustomerEditBanner_ComponentContainer\">\r\n\t\t\t\r\n   \r\n    <h3>Company Profile</h3>\r\n\r\n    <textarea name=\"ctl00$Main$CustomerEditBanner$tbProfileDescription\" rows=\"10\" cols=\"20\" id=\"Main_CustomerEditBanner_tbProfileDescription\" style=\"width:440px;font-family: Arial; resize: none\">\r\n.incotech - Ihr freundliches Systemhaus aus Nordhessen ||\n\nUnsere modernen und hochsicheren Client-Server- und Firewallsysteme sorgen daf&#252;r, dass Sie zuverl&#228;ssig und sicher Arbeiten k&#246;nnen. || Telekommunikation - f&#252;hrender 3CX-Partner der Region. || Vom einzelnen Telefon bis hin zur komplexen Telefonanlage mit mehreren hundert Nebenstellen und weltumspannender Vernetzung. Bei uns erhalten Sie die Beratung, Service und Betreuung, um moderne Technik effizient und sicher zu nutzen. || Platin zertifiziert, T&#220;V-gepr&#252;ft und &#252;ber 20 Jahre Erfahrung: Unser Anspruch f&#252;r Ihre Sicherheit.</textarea>\r\n\r\n    <h3>Company Banner</h3>\r\n    \r\n\r\n    <div id=\"Main_CustomerEditBanner_ImageUpdatePanel\">\r\n\t\t\t\t\r\n            <p><img id=\"Main_CustomerEditBanner_LogoImg\" src=\"data:image/jpeg;base64,\" /></p>\r\n            <p id=\"Main_CustomerEditBanner_RemoveLogoPnl\"><a onclick=\"return ConfirmRemoveBanner();\" id=\"Main_CustomerEditBanner_RemoveLogoBtn\" href=\"javascript:__doPostBack(&#39;ctl00$Main$CustomerEditBanner$RemoveLogoBtn&#39;,&#39;&#39;)\">Remove Banner</a></p>\r\n                \r\n\r\n<div class=\"messagebox\">\r\n    <div id=\"Main_CustomerEditBanner_MessageBox_pnlMessage\">\r\n\t\t\t\t\t\r\n        <div class=\"btn\"></div>\r\n        <span id=\"Main_CustomerEditBanner_MessageBox_lblText\"></span>\r\n    \r\n\t\t\t\t</div>\r\n</div>\r\n                <div id=\"Main_CustomerEditBanner_LogoFileUpload\">\r\n\t\t\t\t\t<input type=\"hidden\" name=\"ctl00$Main$CustomerEditBanner$LogoFileUpload$ctl00\" id=\"Main_CustomerEditBanner_LogoFileUpload_ctl00\" /><div id=\"Main_CustomerEditBanner_LogoFileUpload_ctl01\"><input name=\"ctl00$Main$CustomerEditBanner$LogoFileUpload$ctl02\" type=\"file\" id=\"ctl00_Main_CustomerEditBanner_LogoFileUpload_ctl02\" style=\"width:400px;\" /></div>\r\n\t\t\t\t</div>\r\n        \r\n\t\t\t</div>\r\n\r\n\r\n\t\t</div>\r\n\r\n                                    </div>\r\n                                </td>\r\n\r\n                                <td>\r\n                                    <div style=\"margin-right: 50px\">\r\n                                        \r\n\r\n<h3>\r\n    Billing Information</h3>\r\n<div id=\"Main_CustomerEditBilling_BillingDetailsUpdatePanel\">\r\n\t\t\t\r\n        <table class=\"c\">\r\n            \r\n                <tr>\r\n                    <td class=\"s\">Billing Address\r\n                    </td>\r\n                    <td>\r\n                        <input name=\"ctl00$Main$CustomerEditBilling$tbAddressLine1\" type=\"text\" value=\"Ehlener Str. 41, Schauenburg, Germany\" maxlength=\"300\" id=\"Main_CustomerEditBilling_tbAddressLine1\" placesapi=\"PlacesApiAutocomplete\" style=\"width:300px;\" /><span id=\"Main_CustomerEditBilling_vldAddressLine1\" class=\"validator\" style=\"display:none;\">Address is required.</span>\r\n                        <div style=\"display: none\">\r\n                            <input name=\"ctl00$Main$CustomerEditBilling$tbAdministrativeArea1\" type=\"text\" id=\"Main_CustomerEditBilling_tbAdministrativeArea1\" placesapi=\"administrative_area_level_1\" /><input name=\"ctl00$Main$CustomerEditBilling$tbAdministrativeArea2\" type=\"text\" id=\"Main_CustomerEditBilling_tbAdministrativeArea2\" placesapi=\"administrative_area_level_2\" /><input name=\"ctl00$Main$CustomerEditBilling$tbPlaceID\" type=\"text\" value=\"ChIJs3I2aOlqu0cRffqwWVFER7U\" id=\"Main_CustomerEditBilling_tbPlaceID\" placesapi=\"place_id\" />\r\n                        </div>\r\n                    </td>\r\n                </tr>\r\n                <tr>\r\n                    <td class=\"s\">Address Line 2</td>\r\n                    <td>\r\n                        <input name=\"ctl00$Main$CustomerEditBilling$tbAddressLine2\" type=\"text\" maxlength=\"300\" id=\"Main_CustomerEditBilling_tbAddressLine2\" style=\"width:300px;\" />\r\n                    </td>\r\n                </tr>\r\n                <tr>\r\n                    <td class=\"s\">Address Line 3</td>\r\n                    <td>\r\n                        <input name=\"ctl00$Main$CustomerEditBilling$tbAddressLine3\" type=\"text\" maxlength=\"300\" id=\"Main_CustomerEditBilling_tbAddressLine3\" style=\"width:300px;\" />\r\n                    </td>\r\n                </tr>\r\n                <tr>\r\n                    <td class=\"s\">City\r\n                    </td>\r\n                    <td>\r\n                        <input name=\"ctl00$Main$CustomerEditBilling$tbCity\" type=\"text\" value=\"Schauenburg\" maxlength=\"50\" id=\"Main_CustomerEditBilling_tbCity\" placesapi=\"locality\" style=\"width:300px;\" /><span id=\"Main_CustomerEditBilling_vldCity\" class=\"validator\" style=\"display:none;\">City is required.</span>\r\n                    </td>\r\n                </tr>\r\n                <tr>\r\n                    <td class=\"s\">State/Province<span id=\"Main_CustomerEditBilling_lblStateStar\" class=\"required\">*</span>\r\n                    </td>\r\n                    <td>\r\n                        <select name=\"ctl00$Main$CustomerEditBilling$ddlState\" id=\"Main_CustomerEditBilling_ddlState\" placesapi=\"administrative_area_level_1\" style=\"width:300px;\">\r\n\t\t\t\t<option value=\"\">-- Select state --</option>\r\n\t\t\t\t<option value=\"BW\">Baden-W&#252;rttemberg</option>\r\n\t\t\t\t<option value=\"BY\">Bayern</option>\r\n\t\t\t\t<option value=\"BE\">Berlin</option>\r\n\t\t\t\t<option value=\"BB\">Brandenburg</option>\r\n\t\t\t\t<option value=\"HB\">Bremen</option>\r\n\t\t\t\t<option value=\"HH\">Hamburg</option>\r\n\t\t\t\t<option selected=\"selected\" value=\"HE\">Hessen</option>\r\n\t\t\t\t<option value=\"MV\">Mecklenburg-Vorpommern</option>\r\n\t\t\t\t<option value=\"NI\">Niedersachsen</option>\r\n\t\t\t\t<option value=\"NW\">Nordrhein-Westfalen</option>\r\n\t\t\t\t<option value=\"RP\">Rheinland-Pfalz</option>\r\n\t\t\t\t<option value=\"SL\">Saarland</option>\r\n\t\t\t\t<option value=\"SN\">Sachsen</option>\r\n\t\t\t\t<option value=\"ST\">Sachsen-Anhalt</option>\r\n\t\t\t\t<option value=\"SH\">Schleswig-Holstein</option>\r\n\t\t\t\t<option value=\"TH\">Th&#252;ringen</option>\r\n\r\n\t\t\t</select><span id=\"Main_CustomerEditBilling_vldState\" class=\"validator\" style=\"display:none;\">State is required.</span>\r\n                    </td>\r\n                </tr>\r\n            \r\n            <tr>\r\n                <td class=\"s\">Zip Code<span class=\"required\">*</span>\r\n                </td>\r\n                <td>\r\n                    <input name=\"ctl00$Main$CustomerEditBilling$tbZipCode\" type=\"text\" value=\"34270\" maxlength=\"20\" id=\"Main_CustomerEditBilling_tbZipCode\" placesapi=\"postal_code\" style=\"width:300px;\" />\r\n                    <span id=\"Main_CustomerEditBilling_vldZipCode\" class=\"validator\" style=\"display:none;\">Zip code is required.</span>\r\n                </td>\r\n            </tr>\r\n            <tr>\r\n                <td class=\"s\">Country<span class=\"required\">*</span>\r\n                </td>\r\n                <td>\r\n                    <select name=\"ctl00$Main$CustomerEditBilling$ddlCountry\" onchange=\"javascript:setTimeout(&#39;__doPostBack(\\&#39;ctl00$Main$CustomerEditBilling$ddlCountry\\&#39;,\\&#39;\\&#39;)&#39;, 0)\" id=\"Main_CustomerEditBilling_ddlCountry\" placesapi=\"country\" style=\"width:300px;\">\r\n\t\t\t\t<option value=\"\">-- Select country -- </option>\r\n\t\t\t\t<option value=\"AF\">Afghanistan</option>\r\n\t\t\t\t<option value=\"AX\">&#197;land Islands</option>\r\n\t\t\t\t<option value=\"AL\">Albania</option>\r\n\t\t\t\t<option value=\"DZ\">Algeria</option>\r\n\t\t\t\t<option value=\"AS\">American Samoa</option>\r\n\t\t\t\t<option value=\"AD\">Andorra</option>\r\n\t\t\t\t<option value=\"AO\">Angola</option>\r\n\t\t\t\t<option value=\"AI\">Anguilla</option>\r\n\t\t\t\t<option value=\"AQ\">Antarctica</option>\r\n\t\t\t\t<option value=\"AG\">Antigua and Barbuda</option>\r\n\t\t\t\t<option value=\"AR\">Argentina</option>\r\n\t\t\t\t<option value=\"AM\">Armenia</option>\r\n\t\t\t\t<option value=\"AW\">Aruba</option>\r\n\t\t\t\t<option value=\"AU\">Australia</option>\r\n\t\t\t\t<option value=\"AT\">Austria</option>\r\n\t\t\t\t<option value=\"AZ\">Azerbaijan</option>\r\n\t\t\t\t<option value=\"BS\">Bahamas</option>\r\n\t\t\t\t<option value=\"BH\">Bahrain</option>\r\n\t\t\t\t<option value=\"BD\">Bangladesh</option>\r\n\t\t\t\t<option value=\"BB\">Barbados</option>\r\n\t\t\t\t<option value=\"BY\">Belarus</option>\r\n\t\t\t\t<option value=\"BE\">Belgium</option>\r\n\t\t\t\t<option value=\"BZ\">Belize</option>\r\n\t\t\t\t<option value=\"BJ\">Benin</option>\r\n\t\t\t\t<option value=\"BM\">Bermuda</option>\r\n\t\t\t\t<option value=\"BT\">Bhutan</option>\r\n\t\t\t\t<option value=\"BO\">Bolivia</option>\r\n\t\t\t\t<option value=\"BQ\">Bonaire, Sint Eustatius and Saba</option>\r\n\t\t\t\t<option value=\"BA\">Bosnia and Herzegowina</option>\r\n\t\t\t\t<option value=\"BW\">Botswana</option>\r\n\t\t\t\t<option value=\"BV\">Bouvet Island</option>\r\n\t\t\t\t<option value=\"BR\">Brazil</option>\r\n\t\t\t\t<option value=\"IO\">British Indian Ocean Territory</option>\r\n\t\t\t\t<option value=\"BN\">Brunei Darussalam</option>\r\n\t\t\t\t<option value=\"BG\">Bulgaria</option>\r\n\t\t\t\t<option value=\"BF\">Burkina Faso</option>\r\n\t\t\t\t<option value=\"BI\">Burundi</option>\r\n\t\t\t\t<option value=\"KH\">Cambodia</option>\r\n\t\t\t\t<option value=\"CM\">Cameroon</option>\r\n\t\t\t\t<option value=\"CA\">Canada</option>\r\n\t\t\t\t<option value=\"IC\">Canary Islands</option>\r\n\t\t\t\t<option value=\"CV\">Cape Verde</option>\r\n\t\t\t\t<option value=\"KY\">Cayman Islands</option>\r\n\t\t\t\t<option value=\"CF\">Central African Republic</option>\r\n\t\t\t\t<option value=\"TD\">Chad</option>\r\n\t\t\t\t<option value=\"CL\"