            "text": "var popupCloseFunction = null;\r\n\r\nfunction ismsie() {\r\n    var ua = window.navigator.userAgent;\r\n    var msie = ua.indexOf(\"MSIE \");\r\n    return msie > 0 || !!navigator.userAgent.match(/Trident.*rv\\:11\\./); // If Internet Explorer, return version number\r\n}\r\n\r\nfunction adjustPopupDimensions() {\r\n    var $ = jQuery;\r\n    $(\".popup\").each(function () {\r\n        if (!$(this).is(\":visible\")) return;\r\n\r\n        var maxWidth = $(window).width() * 0.9;\r\n        var maxHeight = $(window).height() * 0.9;\r\n        var child = $(this).children(\":first\");\r\n        var scrollable = child.find(\".scrollable :first\");\r\n\r\n        if (child.data(\"orig-width\") == null) child.data(\"orig-width\", child.outerWidth());\r\n        if (child.data(\"orig-height\") == null) child.data(\"orig-height\", child.outerHeight());\r\n        if (child.data(\"orig-scrollable-height\") == null && scrollable.length > 0) child.data(\"orig-scrollable-height\", scrollable.height());\r\n\r\n        var origWidth = child.data(\"orig-width\");\r\n        var origHeight = child.data(\"orig-height\");\r\n\r\n        $(this).css(\"marginLeft\", \"-\" + Math.min(origWidth, maxWidth) / 2 + \"px\");\r\n\r\n        if (origWidth > maxWidth) {\r\n            child.css(\"width\", maxWidth + \"px\");\r\n        }\r\n        else {\r\n            child.css(\"width\", origWidth + \"px\");\r\n        }\r\n\r\n        $(this).css(\"marginTop\", \"-\" + Math.min(origHeight, maxHeight) / 2 + \"px\");\r\n\r\n        if (origHeight > maxHeight) {\r\n            child.css(\"height\", maxHeight + 35.0 + \"px\");\r\n            if (scrollable.length > 0) scrollable.css(\"height\", (child.data(\"orig-scrollable-height\") + maxHeight - origHeight) + \"px\");\r\n        }\r\n        else {\r\n            child.css(\"height\", origHeight + 35.0 + \"px\");\r\n            if (scrollable.length > 0) scrollable.css(\"height\", child.data(\"orig-scrollable-height\") + \"px\");\r\n        }\r\n    });\r\n}\r\n\r\nfunction showPopup(obj, closefunc, completefunc) {\r\n    var $ = jQuery;\r\n    popupCloseFunction = typeof (closefunc) != \"undefined\" ? closefunc : null;\r\n    $(\"#popupbg\").height($(document).height());\r\n    $(\"#popupbg\").fadeIn();\r\n\r\n    if (typeof completefunc == \"undefined\") $(\"#\" + obj).fadeIn();\r\n    else $(\"#\" + obj).fadeIn(500, completefunc);\r\n\r\n    adjustPopupDimensions();\r\n    return false;\r\n}\r\n\r\nfunction hidePopupBg() {\r\n    jQuery(\"#popupbg\").fadeOut();\r\n    return false;\r\n}\r\n\r\nfunction hidePopup(obj, closefunc) {\r\n    popupCloseFunction = typeof (closefunc) != \"undefined\" ? closefunc : null;\r\n    hidePopupBg();\r\n    jQuery(\"#\" + obj).fadeOut();\r\n    return false;\r\n}\r\n\r\nfunction hidePopupNotBg(obj, closefunc) {\r\n    popupCloseFunction = typeof (closefunc) != \"undefined\" ? closefunc : null;\r\n    jQuery(\"#\" + obj).fadeOut();\r\n    return false;\r\n}\r\n\r\nfunction forceAjaxTabsSameHeight() {\r\n    var $ = jQuery;\r\n    $(\".popup\").find(\".ajax__tab_body\").each(function () {\r\n        var outerHeight = 0;\r\n        $(this).children().each(function () {\r\n            $(this).css(\"height\", \"\");\r\n            var pageHeight = $(this).outerHeight(true);\r\n            if (pageHeight > outerHeight) outerHeight = pageHeight;\r\n        });\r\n        $(this).children().each(function () {\r\n            var paddingMarginBorder = $(this).outerHeight(true) - $(this).height();\r\n            $(this).height(outerHeight + paddingMarginBorder);\r\n        });\r\n        var outerPaddingMarginBorder = $(this).outerHeight(true) - $(this).height();\r\n        $(this).height(outerHeight + outerPaddingMarginBorder + 50);\r\n    });\r\n}\r\n\r\nfunction refreshPopupLayout() {\r\n    var $ = jQuery;\r\n    forceAjaxTabsSameHeight();\r\n    $(\".popup\").each(function () {\r\n        var child = $(this).children(\":first\");\r\n        child.removeData();\r\n        child.css(\"height\", \"\");\r\n        adjustPopupDimensions();\r\n    });\r\n    return true;\r\n}\r\n\r\njQuery(document).ready(function ($) {\r\n    var progressTimer = null;\r\n\r\n    $(document).keydown(function (e) {\r\n        if (e.keyCode == 27 && typeof (popupCloseFunction) != \"undefined\" && popupCloseFunction != null) {\r\n            var oldPopupCloseFunction = popupCloseFunction;\r\n            popupCloseFunction();\r\n            if (popupCloseFunction == oldPopupCloseFunction) popupCloseFunction = null;\r\n        }\r\n    });\r\n    $(window).resize(function () {\r\n        adjustPopupDimensions();\r\n    });\r\n\r\n    if (typeof (Sys) != \"undefined\") {\r\n\r\n        var inAjax = false;\r\n\r\n        Sys.WebForms.PageRequestManager.getInstance().add_initializeRequest(function () {\r\n            inAjax = true;\r\n            progressTimer = setTimeout(function () {\r\n                $(\"#progress\").show();\r\n                refreshPopupLayout();\r\n            }, 1000);\r\n        });\r\n        Sys.WebForms.PageRequestManager.getInstance().add_endRequest(function() {\r\n            if (!ismsie()) inAjax = false;\r\n            if (progressTimer != null) {\r\n                clearTimeout(progressTimer);\r\n                progressTimer = null;\r\n            }\r\n            $(\"#progress\").hide();\r\n        });\r\n        Sys.WebForms.PageRequestManager.getInstance().add_pageLoaded(function () {\r\n            inAjax = false;\r\n            if (progressTimer != null) {\r\n                clearTimeout(progressTimer);\r\n                progressTimer = null;\r\n            }\r\n            $(\"#progress\").hide();\r\n            refreshPopupLayout();\r\n        });\r\n    }\r\n});"
