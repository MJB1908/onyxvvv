            "mimeType": "text/css",
            "text": "#webinars table {\r\n    vertical-align: middle;\r\n    font-family: arial, helvetica, sans-serif;\r\n    font-size: 12px;\r\n    border-collapse: separate;\r\n    border-spacing: 2px;\r\n    border-color: grey;\r\n    line-height: 1.5em;\r\n}\r\n#webinars table tr td {\r\n    text-align: left;\r\n    margin: 0;\r\n    font-size: 12px;\r\n}\r\n#webinars table tr.header td {\r\n    background-color: #ccc;\r\n    text-align: left;\r\n    padding: 5px;\r\n    font-weight: bold;\r\n}\r\n#webinars table tr.alt td {\r\n    background-color: #f0f0f0;\r\n    text-align: left;\r\n}\r\n#webinars table tr.description td {\r\n    padding: 20px;\r\n    background-color: rgb(248, 248, 248);\r\n}\r\n#webinars a {\r\n     font-size: 14px;\r\n     color: #007BC7;\r\n}\r\n#webinars table tr td.webinar_full {background-color: #14EF2C; }\r\n#webinars .alt { background: #F0F0F0;}\r\n#webinars .popup {\r\n    font-size: 14px;\r\n}\r\n#webinars .popup #close_button,\r\n#webinars #registered #close_button {\r\n    color: #007BC7;\r\n    text-decoration: none;\r\n}\r\n#webinars .popup input[type=text],\r\n#webinars .popup input[type=email] {\r\n    display: block;\r\n    width: 95%;\r\n    height: 35px;\r\n    font-family: sans-serif;\r\n    font-size: 18px;\r\n    margin-top: 5px;\r\n    background: #fafafa;\r\n    border: 1px solid #ddd;\r\n    color: #888;\r\n    padding: 1px 5px;\r\n}\r\n#webinars .popup input[type=text].error,\r\n#webinars .popup input[type=email].error {\r\n    border: 2px solid red !important;\r\n}\r\n#webinars .popup .label {\r\n    clear: both;\r\n    font: 14px \"Lucida Sans Unicode\", \"Lucida Grande\", sans-serif;\r\n    margin-top: 1em;\r\n}\r\n#webinars .popup img.logo {\r\n    float: right; \r\n    height:77px; \r\n    width:150px;  \r\n    position:relative;\r\n    clear: both;\r\n}\r\n#webinars .popup .button {\r\n    text-align: center;\r\n    margin: 1em 0;\r\n}\r\n#webinars .popup input[type=submit],\r\n#webinars .popup input[type=button]\r\n{\r\n    background: #4B99AD;\r\n    margin: 0 auto;\r\n    height: 25px;\r\n    border: 1px solid #ddd;\r\n    padding: 4px;\r\n    font-size: 12px;\r\n    line-height: 17px;\r\n    width: 150px;\r\n    color: #fff;\r\n}\r\n#webinars .popup p {\r\n    clear: both;\r\n}\r\n"
