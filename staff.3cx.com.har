            "text": "#confirm {\r\n    width: 100%;\r\n}\r\n\r\n    #confirm h3 {\r\n        font-weight: bold !important;\r\n        background: #ebebeb !important;\r\n        padding: 4px !important;\r\n        margin: 0 !important;\r\n        line-height: 1.2em !important;\r\n    }\r\n\r\n    #confirm div.half {\r\n        width: 49%;\r\n        overflow: hidden;\r\n        margin: 0 0 1em 0;\r\n    }\r\n\r\n    #confirm div.full {\r\n        clear: both;\r\n        overflow: hidden;\r\n        margin: 0.5em 0;\r\n    }\r\n\r\n    #confirm div.body {\r\n        border: solid 2px #ebebeb;\r\n        padding: 0.5em;\r\n    }\r\n\r\n    #confirm table.c {\r\n        padding: 0;\r\n        border-collapse: collapse;\r\n    }\r\n\r\n    #confirm table.cart {\r\n        width: 100%;\r\n        padding: 0;\r\n        border-collapse: collapse;\r\n        margin: 0;\r\n    }\r\n\r\n    #confirm table.c td {\r\n        padding: 2px 0;\r\n        vertical-align: baseline;\r\n    }\r\n\r\n        #confirm table.c td.s {\r\n            padding-right: 1em;\r\n            font-weight: bold;\r\n            white-space: nowrap;\r\n        }\r\n\r\n    #confirm table.cart td {\r\n        padding: 4px;\r\n        border: solid 1px #ebebeb;\r\n        vertical-align: baseline;\r\n    }\r\n\r\n    #confirm table.cart tr.header td {\r\n        font-weight: bold;\r\n        background: #ebebeb;\r\n    }\r\n\r\n.regular {\r\n    font-size: 10pt;\r\n    font-family: Arial;\r\n    text-align: justify;\r\n}\r\n\r\n.requiredtext {\r\n    font-size: 8pt;\r\n}\r\n\r\n.validator {\r\n    color: red;\r\n    font-family: Arial;\r\n    margin: 0.5em 0 0.3em 0;\r\n    display: block;\r\n}\r\n\r\n    .validator[style*=\"inline\"] {\r\n        display: block !important;\r\n    }\r\n\r\n.validator2 {\r\n    color: red;\r\n    font-family: Arial;\r\n    margin: 0.5em 0 0.3em 0;\r\n}\r\n\r\n#panel {\r\n    margin: 0;\r\n    padding: 0;\r\n    clear: both;\r\n}\r\n\r\n    #panel #main {\r\n        margin: 8px;\r\n        clear: both;\r\n    }\r\n\r\n    #panel h1 span {\r\n        font-weight: normal;\r\n    }\r\n\r\n    #panel table.datagrid,\r\n    #cart table.datagrid {\r\n        border-collapse: collapse;\r\n    }\r\n\r\n        #panel table.datagrid tr.header td,\r\n        #cart table.datagrid tr.header td,\r\n        #panel table.datagrid tr th,\r\n        #cart table.datagrid tr th {\r\n            font-size: 9pt;\r\n            font-weight: bold;\r\n            background: #F0F0F0;\r\n            white-space: nowrap;\r\n        }\r\n\r\n        #panel table.datagrid td,\r\n        #cart table.datagrid td,\r\n        #panel table.datagrid th,\r\n        #cart table.datagrid th {\r\n            border: solid 1px LightGray;\r\n            vertical-align: top;\r\n            padding: 5px;\r\n        }\r\n\r\n            #panel table.datagrid td.bool,\r\n            #cart table.datagrid td.bool {\r\n                padding: 2px 0.5em;\r\n                text-align: center;\r\n            }\r\n\r\n            #panel table.datagrid td.h,\r\n            #cart table.datagrid td.h {\r\n                white-space: nowrap;\r\n                font-weight: bold;\r\n            }\r\n\r\n            #panel table.datagrid td.r {\r\n                text-align: right;\r\n                white-space: nowrap;\r\n            }\r\n\r\n    #panel .NFRLicenseKeysSection {\r\n        border: 1px solid #aaa;\r\n        padding: 0 1em;\r\n        margin: 1em 0;\r\n        float: left;\r\n    }\r\n\r\n    #panel table.nfrdatagrid {\r\n        border: none;\r\n    }\r\n\r\n        #panel table.nfrdatagrid tr.nfrcomment {\r\n            border-top: 1px solid #ddd;\r\n        }\r\n\r\n            #panel table.nfrdatagrid tr.nfrcomment td {\r\n                padding: 1em 1em 0.5em 0;\r\n            }\r\n\r\n        #panel table.nfrdatagrid tr.header td {\r\n            font-weight: bold;\r\n        }\r\n\r\n        #panel table.nfrdatagrid tr th {\r\n            text-align: left;\r\n            padding: 0.5em 1em 1em 1em;\r\n        }\r\n\r\n        #panel table.nfrdatagrid tr td {\r\n            border: none;\r\n            padding: 0.7em 1em 0.7em 1em;\r\n            vertical-align: top;\r\n        }\r\n\r\n            #panel table.nfrdatagrid tr td.r {\r\n                text-align: right;\r\n            }\r\n\r\n#cart table#productselection tr td.col1 {\r\n    width: 120px;\r\n    padding: 0;\r\n}\r\n\r\n#cart table#productselection tr td.col2 {\r\n    width: 274px;\r\n    padding: 0;\r\n}\r\n\r\n#cart table#productselection tr td.col3 {\r\n    width: 50px;\r\n    padding: 0;\r\n}\r\n\r\n#cart table#productselection tr td.col4 {\r\n    width: 62px;\r\n    padding: 0;\r\n}\r\n\r\n#cart table#productselection .key {\r\n    width: 296px;\r\n    float: left;\r\n}\r\n\r\n#panel div.buttons,\r\n#cart div.buttons {\r\n    clear: both;\r\n    margin: 0.5em 0;\r\n    white-space: nowrap;\r\n}\r\n\r\n#panel div.navigator {\r\n    margin: 0.5em 0;\r\n    white-space: nowrap;\r\n}\r\n\r\n    #panel div.navigator span, #panel div.navigator a {\r\n        margin: 0 0.2em;\r\n    }\r\n\r\n#panel .filter {\r\n    background: #f0f0f0;\r\n    padding: 10px;\r\n    display: inline-block;\r\n    white-space: nowrap;\r\n    text-align: left;\r\n}\r\n\r\n    #panel .filter h2 {\r\n        margin: 0;\r\n    }\r\n\r\n    #panel .filter h3 {\r\n        font-size: 8pt;\r\n        font-weight: normal;\r\n        font-style: italic;\r\n        margin: 0.5em 0 0.2em 0;\r\n    }\r\n\r\n    #panel .filter ul {\r\n        margin: 0;\r\n    }\r\n\r\n        #panel .filter ul li {\r\n            list-style: none;\r\n        }\r\n\r\n    #panel .filter table td {\r\n        padding-right: 0.5em;\r\n        white-space: nowrap;\r\n    }\r\n\r\n#panel table.tabs {\r\n    white-space: nowrap;\r\n    padding: 0;\r\n    border-bottom: solid 1px #a0a0a0;\r\n    width: 100%;\r\n    border-collapse: collapse;\r\n}\r\n\r\n    #panel table.tabs td {\r\n        padding: 2px 0;\r\n    }\r\n\r\n    #panel table.tabs .tabmenu {\r\n        padding: 0.3em 0 0.3em 8px;\r\n    }\r\n\r\n    #panel table.tabs select {\r\n        margin: 0;\r\n        padding: 0;\r\n    }\r\n\r\n    #panel table.tabs a.selected,\r\n    #panel table.subtabs a.selected,\r\n    #top_navigation a.selected {\r\n        text-decoration: underline;\r\n    }\r\n\r\n#panel table.subtabs {\r\n    margin: 1em 0;\r\n}\r\n\r\n#panel .reportstabs {\r\n    white-space: nowrap;\r\n    padding: 0.3em 0.7em;\r\n    border-bottom: solid 1px #a0a0a0;\r\n    font-size: 8.5pt;\r\n}\r\n\r\n.messagebox div.ok {\r\n    padding: 0.7em;\r\n    color: #555;\r\n    font-weight: bold;\r\n    margin: 0;\r\n    background: #cec;\r\n}\r\n\r\n.messagebox div.warn {\r\n    padding: 0.7em;\r\n    color: #227;\r\n    font-weight: bold;\r\n    margin: 0;\r\n    background: #efb200;\r\n}\r\n\r\n.messagebox div.error {\r\n    padding: 0.5em;\r\n    color: #fff;\r\n    margin: 0;\r\n    background: #e33;\r\n}\r\n\r\n.messagebox div.btn {\r\n    float: right;\r\n}\r\n\r\n.messagebox span.link {\r\n    float: right;\r\n}\r\n\r\n.messagebox ul {\r\n    margin: 0;\r\n    padding: 0;\r\n    list-style-type: none;\r\n}\r\n\r\n    .messagebox ul li {\r\n        margin: 0;\r\n        padding: 0;\r\n        list-style-type: none;\r\n    }\r\n\r\n#panel table.dashboardstats {\r\n    background: #ebebeb;\r\n    margin: 0.5em 0;\r\n}\r\n\r\n    #panel table.dashboardstats td {\r\n        padding: 2px;\r\n    }\r\n\r\n    #panel table.dashboardstats .r, #panel table.dashboardstats .rs {\r\n        text-align: right;\r\n        font-weight: bold;\r\n    }\r\n\r\n    #panel table.dashboardstats .rs {\r\n        padding-right: 1em;\r\n    }\r\n\r\n#panel #main .menu ol {\r\n    font-size: 10pt;\r\n}\r\n\r\n#panel table {\r\n    padding: 0;\r\n    border-collapse: collapse;\r\n}\r\n\r\n    #panel table.submit,\r\n    #cart table.submit {\r\n        margin: 0;\r\n        padding: 0;\r\n    }\r\n\r\n        #panel table.submit tr td,\r\n        #cart table.submit tr td {\r\n            padding: 2px 0;\r\n        }\r\n\r\n        #panel table.submit tr.header td,\r\n        #cart table.submit tr.header td {\r\n            font-weight: bold;\r\n        }\r\n\r\n        #panel table.submit .label,\r\n        #cart table.submit .label {\r\n            padding-right: 1em;\r\n            padding-top: 0.3em;\r\n            white-space: nowrap;\r\n            vertical-align: top;\r\n        }\r\n\r\n        #panel table.submit .s,\r\n        #cart table.submit .s {\r\n            padding: 0.3em 1em 0 0;\r\n            white-space: nowrap;\r\n            vertical-align: top;\r\n        }\r\n\r\n#default table.submit .s {\r\n    padding: 0.3em 1em 0 0;\r\n    white-space: nowrap;\r\n}\r\n\r\n#panel table.submit .rememberme,\r\n#cart table.submit .rememberme {\r\n    padding: 0.3em 0;\r\n}\r\n\r\n#cart div.hidden, #cart div.hiddenlabel, #cart div.hiddenrow {\r\n    visibility: hidden;\r\n    display: none;\r\n}\r\n\r\n#cart div.visible {\r\n    visibility: visible;\r\n    display: block;\r\n}\r\n\r\n#cart span.requiredstar {\r\n    font-weight: bold;\r\n    vertical-align: top;\r\n    color: #FF0000;\r\n    position: relative;\r\n    top: -0.2em;\r\n}\r\n\r\n#cart span.requiredstar2 {\r\n    font-weight: bold;\r\n    vertical-align: top;\r\n    color: #FF0000;\r\n    margin: 0 0.3em 0 0;\r\n}\r\n\r\n#cart span.required,\r\n#panel span.required {\r\n    font-size: 0.75em;\r\n    font-weight: bold;\r\n    vertical-align: top;\r\n    color: #FF0000;\r\n    position: relative;\r\n    top: -0.1em;\r\n}\r\n\r\n#panel span.required2,\r\n#cart span.required2 {\r\n    font-size: 0.75em;\r\n    font-weight: bold;\r\n    color: #FF0000;\r\n    margin: 0 0.3em 0 0;\r\n}\r\n\r\n#cart div.label span.required {\r\n    position: relative;\r\n    top: -0.3em;\r\n    left: -0.1em;\r\n}\r\n\r\n#cart span.requiredtext {\r\n    font-size: smaller;\r\n}\r\n\r\n#cart div.label, #cart div.hiddenlabel {\r\n    width: 120px;\r\n    float: left;\r\n    clear: both;\r\n    position: relative;\r\n    top: 0.3em;\r\n}\r\n\r\n#cart div.label, #cart div.hiddenlabel, #cart div.labelfootnote {\r\n    width: 120px;\r\n    float: left;\r\n    clear: both;\r\n}\r\n\r\n#cart div.leftbutton {\r\n    float: left;\r\n}\r\n\r\n#cart div.rightbutton {\r\n    float: right;\r\n}\r\n\r\n#cart div.row, #cart div.hiddenrow {\r\n    clear: both;\r\n    padding-top: 0.2em;\r\n    padding-bottom: 0.2em;\r\n    width: 540px;\r\n}\r\n\r\n#cart div.indentedrow {\r\n    clear: both;\r\n    padding-top: 0.2em;\r\n    padding-bottom: 0.2em;\r\n    width: 420px;\r\n    margin-left: 120px;\r\n}\r\n\r\n#cart img {\r\n    border: none;\r\n}\r\n\r\n#panel .editcust .custtabs {\r\n    white-space: nowrap;\r\n    margin: 1em 0;\r\n    font-weight: bold;\r\n}\r\n\r\n#panel .editcust table.c td {\r\n    padding: 2px 0;\r\n    white-space: nowrap;\r\n}\r\n\r\n#panel .editcust table.c .s {\r\n    width: 135px;\r\n    padding-top: 0.3em;\r\n    padding-right: 0.5em;\r\n}\r\n\r\n#panel table.cols td {\r\n    vertical-align: top;\r\n}\r\n\r\n\r\n#panel table.order {\r\n    border: solid 1px #c0c0c0;\r\n    border-collapse: collapse;\r\n}\r\n\r\n    #panel table.order td {\r\n        white-space: nowrap;\r\n        padding: 2px 4px;\r\n    }\r\n\r\n        #panel table.order td.s {\r\n            padding-right: 1em;\r\n        }\r\n\r\n#panel .disabled {\r\n    color: #c0c0c0;\r\n}\r\n\r\n#panel .inactive {\r\n    color: #909090;\r\n}\r\n\r\n#panel .nodistribute {\r\n    color: #909090;\r\n}\r\n\r\n#panel .potentialpartner {\r\n    color: #ff0000;\r\n}\r\n\r\n#panel .potentialclient {\r\n    font-style: italic;\r\n}\r\n\r\n#panel .nongenuinemac {\r\n    color: #ff0000;\r\n}\r\n\r\n#panel .wrongdetails {\r\n    color: #f00;\r\n}\r\n\r\n#panel .pendingreview {\r\n    color: #efb200;\r\n}\r\n\r\n#panel .verified {\r\n    color: #070;\r\n}\r\n\r\n#panel .getkeyinfo {\r\n    color: #307f7f;\r\n}\r\n\r\n#panel p, #cart p, #default p {\r\n    margin: 0.7em 0;\r\n}\r\n\r\n#panel div.editcust h2 {\r\n    margin: 0.5em 0 0.5em 0;\r\n    background: #f0f0f0;\r\n    padding: 4px 2px;\r\n}\r\n\r\n#panel div.editcust table.submit {\r\n    margin: 0.2em;\r\n}\r\n\r\ntable.report {\r\n    border-collapse: collapse;\r\n    table-layout: fixed;\r\n    clear: both;\r\n}\r\n\r\n    table.report tr.header td {\r\n        font-weight: bold;\r\n        vertical-align: top;\r\n        border-right: solid 1px #e0e0e0;\r\n        border-bottom: none;\r\n        background: #e0e0e0;\r\n    }\r\n\r\n    table.report tr.footer td {\r\n        font-weight: bold;\r\n        vertical-align: top;\r\n        border-top: solid 1px #d0d0d0;\r\n        border-right: dashed 1px #d0d0d0;\r\n        border-bottom: none;\r\n        background: #e0e0e0;\r\n    }\r\n\r\n    table.report tr td {\r\n        padding: 4px 8px;\r\n        text-align: right;\r\n        white-space: nowrap;\r\n        border-right: dashed 1px #d0d0d0;\r\n        border-bottom: solid 1px #d0d0d0;\r\n    }\r\n\r\n        table.report tr td div {\r\n            overflow: hidden;\r\n            white-space: nowrap;\r\n        }\r\n\r\n        table.report tr td.rb {\r\n            border-right: solid 1px #d0d0d0;\r\n        }\r\n\r\n        table.report tr td.alt {\r\n            background-color: #F5F5F5;\r\n        }\r\n\r\n        table.report tr td.arb {\r\n            background-color: #F5F5F5;\r\n            border-right: solid 1px #d0d0d0;\r\n        }\r\n\r\ndiv.welcome {\r\n    padding: 1em;\r\n}\r\n\r\ndiv.group {\r\n    border: solid 1px #c0c0c0;\r\n    padding: 1em;\r\n    margin-right: 0.5em;\r\n    margin-bottom: 0.7em;\r\n    background: #f7f7f7;\r\n}\r\n\r\n    div.group h1 {\r\n        margin: 0 0 1em 0 !important;\r\n        color: #0070f0;\r\n    }\r\n\r\n    div.group input[type=text] {\r\n        border: solid 1px #000000;\r\n    }\r\n\r\ndiv.emailtable table td {\r\n    border: none;\r\n    padding: 0.1em;\r\n    white-space: nowrap;\r\n}\r\n\r\n    div.emailtable table td.l {\r\n        padding-right: 1em;\r\n        vertical-align: top;\r\n        padding-top: 0.2em;\r\n    }\r\n\r\ninput.longtext, select.longtext, textarea.longtext {\r\n    width: 400px;\r\n}\r\n\r\ntextarea.bigarea {\r\n    width: 800px;\r\n    height: 400px;\r\n    resize: none;\r\n}\r\n\r\ndiv.quicklinks a {\r\n    padding-right: 1em;\r\n}\r\n\r\ndiv.sandbox {\r\n    border: 4px solid #ff0000;\r\n    font-weight: bold;\r\n    padding: 0.5em;\r\n    margin: 0.2em 0.2em 1em 0.2em;\r\n    color: #ff0000;\r\n}\r\n\r\ndiv.msg {\r\n    border: 1px solid #ff0000;\r\n    padding: 1em;\r\n    color: #ff0000;\r\n    margin: 0.2em;\r\n}\r\n\r\ndiv.payPalProfileNotice {\r\n    border: 2px solid #c0c0c0;\r\n    padding: 0.5em;\r\n    margin: 1em 0;\r\n    width: 600px;\r\n}\r\n\r\ndiv.payPalError {\r\n    border: 2px solid #ff0000;\r\n    padding: 0.5em;\r\n    margin-bottom: 1em;\r\n    width: 600px;\r\n    color: #ff0000;\r\n}\r\n\r\n    div.payPalError p {\r\n        color: #ff0000;\r\n    }\r\n\r\ntable.callback {\r\n    border-collapse: collapse;\r\n}\r\n\r\n    table.callback th {\r\n        text-align: left;\r\n    }\r\n\r\n    table.callback .validator {\r\n        white-space: normal;\r\n    }\r\n\r\ndiv.callback {\r\n    border: 1px solid #ccc;\r\n    padding: 1em;\r\n    width: 756px;\r\n}\r\n\r\nselect {\r\n    margin: 2px 0;\r\n    padding: 1px;\r\n}\r\n\r\n.expiringPanel {\r\n    margin: 1.5em 0;\r\n    border: 1px solid #c0c0c0;\r\n    padding: 0 1em 1em 1em;\r\n    width: 1024px;\r\n    background: #f7f7f7;\r\n    clear: both;\r\n}\r\n\r\n.contents {\r\n    clear: both;\r\n}\r\n\r\n.hidden {\r\n    display: none;\r\n}\r\n\r\ntable.tblCenter {\r\n    margin: 1em auto;\r\n    background: #f7f7f7;\r\n}\r\n\r\n    table.tblCenter td,\r\n    table.tblCenter th {\r\n        text-align: left;\r\n        padding: 0.2em 1em;\r\n    }\r\n\r\n        table.tblCenter td.r,\r\n        table.tblCenter th.r {\r\n            text-align: right;\