agName.toUpperCase() == \"SELECT\") {\r\n        for (var i = 0; i < elem.options.length; i++) {\r\n            var opt = elem.options[i];\r\n            if (opt.value == str) {\r\n                val = opt.value;\r\n                break;\r\n            }\r\n\r\n            if (opt.text == str) {\r\n                val = opt.value;\r\n                break;\r\n            }\r\n        }\r\n        if (val) elem.value = val;\r\n    }\r\n    return val;\r\n}\r\n\r\nfunction setAddressType(addressType, val1, val2) {\r\n    if (componentForm[addressType]) {\r\n        var elems = getPlacesApiElements(addressType);\r\n        for (var j = 0; j < elems.length; j++) {\r\n            var elem = elems[j];\r\n            var oldval = elem.value;\r\n            var selectVal = '';\r\n            if (elem.tagName.toUpperCase() == \"SELECT\") {\r\n                selectVal = SetSelectValue(elem, val1);\r\n                if (!selectVal)\r\n                    selectVal = SetSelectValue(elem, val2);\r\n            }\r\n            else elem.value = val1;\r\n\r\n            var hasVal = val1 && true;\r\n            if (elem.tagName.toUpperCase() == \"SELECT\")\r\n                hasVal = selectVal && true;\r\n\r\n            if (!hasVal) {\r\n                $(elem).removeAttr('disabled');\r\n                $(elem).removeClass('aspNetDisabled');\r\n            }\r\n            if (addressType === 'country' && oldval !== val1)\r\n                $(elem).trigger('change');\r\n        }\r\n    }\r\n}\r\n\r\nfunction fillInAddress() {\r\n    // Get the place details from the PlacesApiAutocomplete object.\r\n    var place = PlacesApiAutocomplete.getPlace();\r\n    if (typeof place === 'undefined' || !place)\r\n        return;\r\n\r\n    // Get each component of the address from the place details\r\n    // and fill the corresponding field on the form.\r\n    for (var addrType in componentForm) {\r\n        var changed = false;\r\n        for (var i = 0; i < place.address_components.length; i++) {\r\n            var addressType = place.address_components[i].types[0];\r\n            if (addrType !== addressType) continue;\r\n            var val1 = place.address_components[i][componentForm[addrType][0]];\r\n            var val2 = place.address_components[i][componentForm[addrType][1]];\r\n            setAddressType(addrType, val1, val2);\r\n            changed = true;\r\n        }\r\n        if (!changed)\r\n            setAddressType(addrType, '', '');\r\n    }\r\n\r\n    var elem = getPlacesApiElement('place_id');\r\n    elem.value = place.place_id;\r\n    elem = getPlacesApiElement('latitude');\r\n    elem.value = place.geometry.location.lat();\r\n    elem = getPlacesApiElement('longitude');\r\n    elem.value = place.geometry.location.lng();\r\n}\r\n\r\n\r\n$(function () {\r\n    initAutocomplete();\r\n    Sys.WebForms.PageRequestManager.getInstance().add_pageLoaded(function () { initAutocomplete(); });\r\n});\r\n|5146|scriptStartupBlock|ScriptContentNoTags|var PlacesApiAutocomplete2;\r\nvar componentForm = {\r\n    locality: ['long_name', 'long_name'],\r\n    administrative_area_level_1: ['short_name', 'long_name'],\r\n    administrative_area_level_2: ['long_name', 'long_name'],\r\n    country: ['short_name', 'long_name'],\r\n    postal_code: ['short_name', 'short_name']\r\n};\r\nfunction getPlacesApiElement2(name) {\r\n    return getPlacesApiElements2(name)[0];\r\n}\r\nfunction getPlacesApiElements2(name) {\r\n    return $(\"[placesapi='\" + name + \"2']\");\r\n}\r\n\r\nfunction initAutocomplete2() {\r\n    if (typeof google === 'undefined' || !google)\r\n        return;\r\n    var elem = getPlacesApiElement2('PlacesApiAutocomplete');\r\n    if (elem) {\r\n        PlacesApiAutocomplete2 = new google.maps.places.Autocomplete(elem, { types: ['geocode'] });\r\n        PlacesApiAutocomplete2.addListener('place_changed', fillInAddress2);\r\n        PlacesApiAutocomplete2.setComponentRestrictions({ 'country': [getPlacesApiElement2('country').value] });\r\n    }\r\n}\r\n\r\nfunction ShowEditPopup(showCoordinates) {\r\n    initAutocomplete2();\r\n    if (showCoordinates) {\r\n        $('#trLatitude').show();\r\n        $('#trLongitude').show();\r\n    }\r\n    else {\r\n        $('#trLatitude').hide();\r\n        $('#trLongitude').hide();\r\n    }\r\n    bootstrap.Modal.getOrCreateInstance('#Main_CustomerAdditionalListings_EditAddressPopup').show();\r\n\r\n    $('#Main_CustomerAdditionalListings_tbCompanyName').focus();\r\n}\r\n\r\nfunction HideEditPopup() {\r\n    $('#Main_CustomerAdditionalListings_EditAddressPopup').modal('hide');\r\n}\r\n\r\nfunction OnCountryChanged2() {\r\n    PlacesApiAutocomplete2.setComponentRestrictions({ 'country': [getPlacesApiElement2('country').value] });\r\n\r\n    var elem = getPlacesApiElement2('place_id');\r\n    if (elem) elem.value = null;\r\n    elem = getPlacesApiElement2('latitude');\r\n\r\n    if (elem) elem.value = null;\r\n    elem = getPlacesApiElement2('longitude');\r\n\r\n    if (elem) elem.value = null;\r\n\r\n    elem = getPlacesApiElement2('PlacesApiAutocomplete');\r\n    if (elem) elem.value = null;\r\n\r\n    elem = getPlacesApiElement2('locality');\r\n    if (elem) elem.value = null;\r\n\r\n    elem = getPlacesApiElement2('administrative_area_level_1');\r\n    if (elem) elem.value = null;\r\n\r\n    elem = getPlacesApiElement2('postal_code');\r\n    if (elem) elem.value = null;\r\n}\r\n\r\nfunction SetSelectValue2(elem, str) {\r\n    var val = '';\r\n    if (elem.tagName.toUpperCase() == \"SELECT\") {\r\n        for (var i = 0; i < elem.options.length; i++) {\r\n            var opt = elem.options[i];\r\n            if (opt.value == str) {\r\n                val = opt.value;\r\n                break;\r\n            }\r\n\r\n            if (opt.text == str) {\r\n                val = opt.value;\r\n                break;\r\n            }\r\n        }\r\n        if (val) elem.value = val;\r\n    }\r\n    return val;\r\n}\r\n\r\nfunction setAddressType2(addressType, val1, val2) {\r\n    if (componentForm[addressType]) {\r\n        var elems = getPlacesApiElements2(addressType);\r\n        for (var j = 0; j < elems.length; j++) {\r\n            var elem = elems[j];\r\n            var oldval = elem.value;\r\n            var selectVal = '';\r\n            if (elem.tagName.toUpperCase() == \"SELECT\") {\r\n                selectVal = SetSelectValue2(elem, val1);\r\n                if (!selectVal)\r\n                    selectVal = SetSelectValue2(elem, val2);\r\n            }\r\n            else elem.value = val1;\r\n\r\n            var hasVal = val1 && true;\r\n            if (elem.tagName.toUpperCase() == \"SELECT\")\r\n                hasVal = selectVal && true;\r\n\r\n            if (!hasVal) {\r\n                $(elem).removeAttr('disabled');\r\n                $(elem).removeClass('aspNetDisabled');\r\n            }\r\n            if (addressType === 'country' && oldval !== val1)\r\n                $(elem).trigger('change');\r\n        }\r\n    }\r\n}\r\n\r\nfunction fillInAddress2() {\r\n    // Get the place details from the PlacesApiAutocomplete object.\r\n    var place = PlacesApiAutocomplete2.getPlace();\r\n    if (typeof place === 'undefined' || !place)\r\n        return;\r\n\r\n    // Get each component of the address from the place details\r\n    // and fill the corresponding field on the form.\r\n    for (var addrType in componentForm) {\r\n        var changed = false;\r\n        for (var i = 0; i < place.address_components.length; i++) {\r\n            var addressType = place.address_components[i].types[0];\r\n            if (addrType !== addressType) continue;\r\n            var val1 = place.address_components[i][componentForm[addrType][0]];\r\n            var val2 = place.address_components[i][componentForm[addrType][1]];\r\n            setAddressType2(addrType, val1, val2);\r\n            changed = true;\r\n        }\r\n        if (!changed)\r\n            setAddressType2(addrType, '', '');\r\n    }\r\n\r\n    var elem = getPlacesApiElement2('place_id');\r\n    elem.value = place.place_id;\r\n    elem = getPlacesApiElement2('latitude');\r\n    elem.value = place.geometry.location.lat();\r\n    elem = getPlacesApiElement2('longitude');\r\n    elem.value = place.geometry.location.lng();\r\n}\r\n\r\n\r\n$(function () {\r\n    initAutocomplete2();\r\n    Sys.WebForms.PageRequestManager.getInstance().add_pageLoaded(function () { initAutocomplete2(); });\r\n});\r\n|281|scriptStartupBlock|ScriptContentNoTags|\r\nvar Page_ValidationActive = false;\r\nif (typeof(ValidatorOnLoad) == \"function\") {\r\n    ValidatorOnLoad();\r\n}\r\n\r\nfunction ValidatorOnSubmit() {\r\n    if (Page_ValidationActive) {\r\n        return ValidatorCommonOnSubmit();\r\n    }\r\n    else {\r\n        return true;\r\n    }\r\n}\r\n        |192|scriptStartupBlock|ScriptContentNoTags|\r\ndocument.getElementById('Main_CustomerEditContact_vldCompany').dispose = function() {\r\n    Array.remove(Page_Validators, document.getElementById('Main_CustomerEditContact_vldCompany'));\r\n}\r\n|196|scriptStartupBlock|ScriptContentNoTags|\r\ndocument.getElementById('Main_CustomerEditContact_vldFirstName').dispose = function() {\r\n    Array.remove(Page_Validators, document.getElementById('Main_CustomerEditContact_vldFirstName'));\r\n}\r\n|194|scriptStartupBlock|ScriptContentNoTags|\r\ndocument.getElementById('Main_CustomerEditContact_vldLastName').dispose = function() {\r\n    Array.remove(Page_Validators, document.getElementById('Main_CustomerEditContact_vldLastName'));\r\n}\r\n|188|scriptStartupBlock|ScriptContentNoTags|\r\ndocument.getElementById('Main_CustomerEditContact_vldEmail').dispose = function() {\r\n    Array.remove(Page_Validators, document.getElementById('Main_CustomerEditContact_vldEmail'));\r\n}\r\n|190|scriptStartupBlock|ScriptContentNoTags|\r\ndocument.getElementById('Main_CustomerEditContact_vldEmail2').dispose = function() {\r\n    Array.remove(Page_Validators, document.getElementById('Main_CustomerEdit