ributor/SP Override</h3>\r\n    <table class=\"submit\" style=\"margin: 0\">\r\n        <tr>\r\n            <td class=\"s\">Can Order Direct</td>\r\n            <td>\r\n                <input id=\"Main_CustomerEditParent_cbCanOrderDirect\" type=\"checkbox\" name=\"ctl00$Main$CustomerEditParent$cbCanOrderDirect\" /></td>\r\n        </tr>\r\n    </table>\r\n\r\n\r\n<div id=\"Main_CustomerEditParent_DirectPurchasesEndusers\" style=\"margin-top: 10px\">\r\n\t\t\t\t\r\n    <h3>End-User Rights</h3>\r\n    <div id=\"Main_CustomerEditParent_upDirectPurchasesEndusers\">\r\n\t\t\t\t\t\r\n            <table>\r\n                <tr>\r\n                    <td colspan=\"2\"><span>Select which rights assigned customers shall have while linked to this account:</span></td>\r\n                </tr>\r\n                <tr>\r\n                    <td>\r\n                        <table class=\"submit\" style=\"margin: 0; margin-right: 60px;\">\r\n                            <tr>\r\n                                <td colspan=\"2\"><span>Onboarded by 3CX</span></td>\r\n                            </tr>\r\n                            <tr>\r\n                                <td class=\"s\">Unlink Themself</td>\r\n                                <td>\r\n                                    <input id=\"Main_CustomerEditParent_cbAllowSelfOnboardedEnduserUnlink\" type=\"checkbox\" name=\"ctl00$Main$CustomerEditParent$cbAllowSelfOnboardedEnduserUnlink\" checked=\"checked\" /></td>\r\n                            </tr>\r\n                            <tr id=\"Main_CustomerEditParent_tr1\">\r\n\t\t\t\t\t\t<td class=\"s\">Buy Subscriptions</td>\r\n\t\t\t\t\t\t<td>\r\n                                    <input id=\"Main_CustomerEditParent_cbAllowSelfOnboardedEnduserPurchases\" type=\"checkbox\" name=\"ctl00$Main$CustomerEditParent$cbAllowSelfOnboardedEnduserPurchases\" /></td>\r\n\t\t\t\t\t</tr>\r\n\t\t\t\t\t\r\n                            <tr id=\"Main_CustomerEditParent_tr2\">\r\n\t\t\t\t\t\t<td class=\"s\">Buy Upgrades</td>\r\n\t\t\t\t\t\t<td>\r\n                                    <input id=\"Main_CustomerEditParent_cbAllowSelfOnboardedEnduserUpgrades\" type=\"checkbox\" name=\"ctl00$Main$CustomerEditParent$cbAllowSelfOnboardedEnduserUpgrades\" /></td>\r\n\t\t\t\t\t</tr>\r\n\t\t\t\t\t\r\n                            <tr id=\"Main_CustomerEditParent_tr3\">\r\n\t\t\t\t\t\t<td class=\"s\">Renew Subscriptions</td>\r\n\t\t\t\t\t\t<td>\r\n                                    <input id=\"Main_CustomerEditParent_cbAllowSelfOnboardedEnduserRenewals\" type=\"checkbox\" name=\"ctl00$Main$CustomerEditParent$cbAllowSelfOnboardedEnduserRenewals\" checked=\"checked\" /></td>\r\n\t\t\t\t\t</tr>\r\n\t\t\t\t\t\r\n                        </table>\r\n                    </td>\r\n                    <td>\r\n                        <table class=\"submit\" style=\"margin: 0;\">\r\n                            <tr>\r\n                                <td colspan=\"2\"><span>Onboarded by  Partner </span></td>\r\n                            </tr>\r\n                            <tr>\r\n                                <td class=\"s\">Unlink Themself</td>\r\n                                <td>\r\n                                    <input id=\"Main_CustomerEditParent_cbAllowEnduserUnlink\" type=\"checkbox\" name=\"ctl00$Main$CustomerEditParent$cbAllowEnduserUnlink\" /></td>\r\n                            </tr>\r\n                            <tr id=\"Main_CustomerEditParent_tr7\">\r\n\t\t\t\t\t\t<td class=\"s\">Buy Subscriptions</td>\r\n\t\t\t\t\t\t<td>\r\n                                    <input id=\"Main_CustomerEditParent_cbAllowEnduserPurchases\" type=\"checkbox\" name=\"ctl00$Main$CustomerEditParent$cbAllowEnduserPurchases\" /></td>\r\n\t\t\t\t\t</tr>\r\n\t\t\t\t\t\r\n                            <tr>\r\n                                <td class=\"s\">Buy Upgrades</td>\r\n                                <td>\r\n                                    <input id=\"Main_CustomerEditParent_c