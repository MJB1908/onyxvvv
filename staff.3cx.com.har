=\"3\">\r\n                <input name=\"ctl00$Main$CustomerEditBilling$tbSageID\" type=\"text\" value=\"INCGM1\" maxlength=\"6\" readonly=\"readonly\" id=\"Main_CustomerEditBilling_tbSageID\" style=\"width:100px;\" /></td>\r\n        </tr>\r\n    \r\n    <tr>\r\n        <td class=\"s\">Overwrite Sales Region for Sales Reports</td>\r\n        <td colspan=\"3\">\r\n            <select name=\"ctl00$Main$CustomerEditBilling$ddlOverwritSalesRegion\" id=\"Main_CustomerEditBilling_ddlOverwritSalesRegion\" style=\"width:300px;\">\r\n\t\t\t<option selected=\"selected\" value=\"\"></option>\r\n\t\t\t<option value=\"7\">Africa</option>\r\n\t\t\t<option value=\"26\">Asia</option>\r\n\t\t\t<option value=\"10\">Australasia</option>\r\n\t\t\t<option value=\"20\">BeNeLux</option>\r\n\t\t\t<option value=\"25\">Canada</option>\r\n\t\t\t<option value=\"5\">Central Europe</option>\r\n\t\t\t<option value=\"6\">Eastern Europe</option>\r\n\t\t\t<option value=\"18\">France</option>\r\n\t\t\t<option value=\"21\">Iberia</option>\r\n\t\t\t<option value=\"9\">Italy</option>\r\n\t\t\t<option value=\"15\">Middle East North Africa</option>\r\n\t\t\t<option value=\"29\">Russia</option>\r\n\t\t\t<option value=\"2\">Scandinavia</option>\r\n\t\t\t<option value=\"1\">South &amp; Central America</option>\r\n\t\t\t<option value=\"4\">UK &amp; Ireland</option>\r\n\t\t\t<option value=\"8\">United States</option>\r\n\r\n\t\t</select>\r\n        </td>\r\n    </tr>\r\n</table>\r\n\r\n\r\n                                    </div>\r\n                                </td>\r\n                                <td>\r\n                                    <div>\r\n                                        \r\n<h3><span id=\"Main_CustomerEditCreditLimit_lblTitle\">Credit Terms (Optional)</span></h3>\r\n<table>\r\n        <tr>\r\n            <td>Credit Limit</td>\r\n            <td>\r\n                <input name=\"ctl00$Main$CustomerEditCreditLimit$tbCreditLimit\" type=\"text\" readonly=\"readonly\" id=\"Main_CustomerEditCreditLimit_tbCreditLimit\" />\r\n                <span id=\"Main_CustomerEditCreditLimit_vldCreditLimit\" class=\"validator\" style=\"display:none;\">Enter a valid credit limit amount.</span>\r\n            </td>\r\n        </tr>\r\n        <tr>\r\n            <td>Current Credit</td>\r\n            <td>\r\n                <b>0.00</b>\r\n            </td>\r\n        </tr>\r\n</table>\r\n<p id=\"Main_CustomerEditCreditLimit_DownloadStatementSection\">\r\n    <input type=\"submit\" name=\"ctl00$Main$CustomerEditCreditLimit$DownloadStatementBtn\" value=\"Download Statement\" onclick=\"javascript:WebForm_DoPostBackWithOptions(new WebForm_PostBackOptions(&quot;ctl00$Main$CustomerEditCreditLimit$DownloadStatementBtn&quot;, &quot;&quot;, true, &quot;&quot;, &quot;&quot;, false, false))\" id=\"Main_CustomerEditCreditLimit_DownloadStatementBtn\" />\r\n</p>\r\n\r\n                                        \r\n                                    </div>\r\n                                </td>\r\n                            </tr>\r\n                        </table>\r\n                    \r\n\t</div>\r\n\r\n                    \r\n\r\n                    \r\n\r\n                    \r\n                    \r\n                    \r\n                    <div id=\"Main_pnlStatistics\" class=\"tab-panel\">\r\n\t\t\r\n                        \r\n<h3>Statistics</h3>\r\n<table class=\"c\">\r\n    <tr>\r\n        <td class=\"s\">\r\n            <span style=\"width:300px\">Score</span>\r\n        </td>\r\n        <td>\r\n            <span id=\"Main_CustomerEditStats_lblScore\" style=\"display:inline-block;font-weight:bold;width:300px;\">0</span></td>\r\n    </tr>\r\n    \r\n            <tr>\r\n                <td class=\"s\">\r\n                    <span id=\"Main_CustomerEditStats_rpAnswers_lblQuestion_0\" style=\"display:inline-block;width:300px;white-space:normal\">What is your preferred purchasing method?</span>\r\n                </td>\r\n                <td>\r\n                    <span id=\"Main_CustomerEditStats_rpAnswers_lblAnswer_0\" style=\"display:inline-block;font-weight:bold;width:300px;white-space:normal\">I prefer to order via Distribution</span>\r\n                </td>\r\n            </tr>\r\n        \r\n            <tr>\r\n                <td class=\"s\">\r\n                    <span id=\"Main_CustomerEditStats_rpAnswers_lblQuestion_1\" style=\"display:inline-block;width:300px;white-space:normal\">Would you recommend 3CX to other MSPs/ Communications providers?</span>\r\n                </td>\r\n                <td>\r\n                    <span id=\"Main_CustomerEditStats_rpAnswers_lblAnswer_1\" style=\"display:inline-block;font-weight:bold;width:300px;white-space:normal\">Yes</span>\r\n                </td>\r\n            </tr>\r\n        \r\n            <tr>\r\n                <td class=\"s\">\r\n                    <span id=\"Main_CustomerEditStats_rpAnswers_lblQuestion_2\" style=\"display:inline-block;width:300px;white-space:normal\">We will continue our partnership with 3CX indefinitely</span>\r\n                </td>\r\n                <td>\r\n                    <span id=\"Main_CustomerEditStats_rpAnswers_lblAnswer_2\" style=\"display:inline-block;font-weight:bold;width:300px;white-space:normal\">Strongly Agree</span>\r\n                </td>\r\n            </tr>\r\n        \r\n            <tr>\r\n                <td class=\"s\">\r\n                    <span id=\"Main_CustomerEditStats_rpAnswers_lblQuestion_3\" style=\"display:inline-block;width:300px;white-space:normal\">Do you actively approach your existing customers and introduce them to 3CX?</span>\r\n                </td>\r\n                <td>\r\n                    <span id=\"Main_CustomerEditStats_rpAnswers_lblAnswer_3\" style=\"display:inline-block;font-weight:bold;width:300px;white-space:normal\">Yes</span>\r\n                </td>\r\n            </tr>\r\n        \r\n            <tr>\r\n                <td class=\"s\">\r\n                    <span id=\"Main_CustomerEditStats_rpAnswers_lblQuestion_4\" style=\"display:inline-block;width:300px;white-space:normal\">Which applications would you like to see 3CX supporting in the future</span>\r\n                </td>\r\n                <td>\r\n                    <span id=\"Main_CustomerEditStats_rpAnswers_lblAnswer_4\" style=\"display:inline-block;font-weight:bold;width:300px;white-space:normal\">Applications (.)</span>\r\n                </td>\r\n            </tr>\r\n        \r\n            <tr>\r\n                <td class=\"s\">\r\n                    <span id=\"Main_CustomerEditStats_rpAnswers_lblQuestion_5\" style=\"display:inline-block;width:300px;white-space:normal\">Would you be interested in a low-cost, certified 3CX appliance (Approximate cost: $200-$300 per unit)?</span>\r\n                </td>\r\n                <td>\r\n                    <span id=\"Main_CustomerEditStats_rpAnswers_lblAnswer_5\" style=\"display:inline-block;font-weight:bold;width:300px;white-space:normal\">Yes</span>\r\n                </td>\r\n            </tr>\r\n        \r\n            <tr>\r\n                <td class=\"s\">\r\n                    <span id=\"Main_CustomerEditStats_rpAnswers_lblQuestion_6\" style=\"display:inline-block;width:300px;white-space:normal\">How do the majority of your customer’s deploy 3CX?</span>\r\n                </td>\r\n                <td>\r\n                    <span id=\"Main_CustomerEditStats_rpAnswers_lblAnswer_6\" style=\"display:inline-block;font-weight:bold;width:300px;white-space:normal\">On-Premise</span>\r\n                </td>\r\n            </tr>\r\n        \r\n            <tr>\r\n                <td class=\"s\">\r\n                    <span id=\"Main_CustomerEditStats_rpAnswers_lblQuestion_7\" style=\"display:inline-block;width:300px;white-space:normal\">Would you like 3CX to provide you with a hosted/managed instance for resale?</span>\r\n                </td>\r\n                <td>\r\n                    <span id=\"Main_CustomerEditStats_rpAnswers_lblAnswer_7\" style=\"display:inline-block;font-weight:bold;width:300px;white-space:normal\">Yes</span>\r\n                </td>\r\n            </tr>\r\n        \r\n            <tr>\r\n                <td class=\"s\">\r\n                    <span id=\"Main_CustomerEditStats_rpAnswers_lblQuestion_8\" style=\"display:inline-block;width:300px;white-space:normal\">In 2019 we added 3CX Click2Talk to all 3CX Editions. Do you feel this added value to the product?</span>\r\n                </td>\r\n                <td>\r\n                    <span id=\"Main_CustomerEditStats_rpAnswers_lblAnswer_8\" style=\"display:inline-block;font-weight:bold;width:300px;white-space:normal\">Yes</span>\r\n                </td>\r\n            </tr>\r\n        \r\n            <tr>\r\n                <td class=\"s\">\r\n                    <span id=\"Main_CustomerEditStats_rpAnswers_lblQuestion_9\" style=\"display:inline-block;width:300px;white-space:normal\">Partnering with 3CX is mutually beneficial</span>\r\n                </td>\r\n                <td>\r\n                    <span id=\"Main_CustomerEditStats_rpAnswers_lblAnswer_9\" style=\"display:inline-block;font-weight:bold;width:300px;white-space:normal\">Agree</span>\r\n                </td>\r\n            </tr>\r\n        \r\n            <tr>\r\n                <td class=\"s\">\r\n                    <span id=\"Main_CustomerEditStats_rpAnswers_lblQuestion_10\" style=\"display:inline-block;width:300px;white-space:normal\">My sales have increased as a 3CX partner</span>\r\n                </td>\r\n                <td>\r\n                    <span id=\"Main_CustomerEditStats_rpAnswers_lblAnswer_10\" style=\"display:inline-block;font-weight:bold;width:300px;white-space:normal\">Agree</span>\r\n                </td>\r\n            </tr>\r\n        \r\n            <tr>\r\n                <td class=\"s\">\r\n                    <span id=\"Main_CustomerEditStats_rpAnswers_lblQuestion_11\" style=\"display:inline-block;width:300px;white-space:normal\">3CX provides my business with the tools we need to succeed</span>\r\n                </td>\r\n                <td>\r\n                    <span id=\"Main_CustomerEditStats_rpAnswers_lblAnswer_11\" style=\"display:inline-block;font-weight:bold;width:300px;white-space:normal\">Agree</span>\r\n                </td>\r\n            </tr>\r\n        \r\n            <tr>\r\n                <td class=\"s\">\r\n                    <span id=\"Main_CustomerEditStats_rpAnswers_lblQuestion_12\" style=\"display:inline-block;width:300px;white-space:normal\">How do you rate the service you receive from Sales Support?</span>\r\n                </td>\r\n                <td>\r\n                    <span id=\"Main_CustomerEditStats_rpAnswers_lblAnswer_12\" style=\"display:inline-block;font-weight:bold;width:300px;white-space:normal\">Good</span>\r\n                </td>\r\n            </tr>\r\n        \r\n            <tr>\r\n                <td class=\"s\">\r\n                    <span id=\"Main_CustomerEditStats_rpAnswers_lblQuestion_13\" style=\"display:inline-block;width:300px;white-space:normal\">How do you rate the service you receive from Customer Service/ General Enquiries?</span>\r\n                </td>\r\n                <td>\r\n                    <span id=\"Main_CustomerEditStats_rpAnswers_lblAnswer_13\" style=\"display:inline-block;font-weight:bold;width:300px;white-space:normal\">Good</span>\r\n                </td>\r\n            </tr>\r\n        \r\n            <tr>\r\n                <td class=\"s\">\r\n                    <span id=\"Main_CustomerEditStats_rpAnswers_lblQuestion_14\" style=\"display:inline-block;width:300px;white-space:normal\">Would FXS, FXO ports be interesting?</span>\r\n                </td>\r\n                <td>\r\n                    <span id=\"Main_CustomerEditStats_rpAnswers_lblAnswer_14\" style=\"display:inline-block;font-weight:bold;width:300px;white-space:normal\">Yes FXS ports would be interesting</span>\r\n                </td>\r\n            </tr>\r\n        \r\n            <tr>\r\n                <td class=\"s\">\r\n                    <span id=\"Main_CustomerEditStats_rpAnswers_lblQuestion_15\" style=\"display:inline-block;width:300px;white-space:normal\">We plan to expand the web-chat with SMS support. Do you believe this beneficial?</span>\r\n                </td>\r\n                <td>\r\n                    <span id=\"Main_CustomerEditStats_rpAnswers_lblAnswer_15\" style=\"display:inline-block;font-weight:bold;width:300px;white-space:normal\">No</span>\r\n                </td>\r\n            </tr>\r\n        \r\n            <tr>\r\n                <td class=\"s\">\r\n                    <span id=\"Main_CustomerEditStats_rpAnswers_lblQuestion_16\" style=\"display:inline-block;width:300px;white-space:normal\">When adding phone lines to your 3CX solutions, do you use:</span>\r\n                </td>\r\n                <td>\r\n                    <span id=\"Main_CustomerEditStats_rpAnswers_lblAnswer_16\" style=\"display:inline-block;font-weight:bold;width:300px;white-space:normal\">Mostly SIP Trunks</span>\r\n                </td>\r\n            </tr>\r\n        \r\n            <tr>\r\n                <td class=\"s\">\r\n                    <span id=\"Main_CustomerEditStats_rpAnswers_lblQuestion_17\" style=\"display:inline-block;width:300px;white-space:normal\">How did you get to know about 3CX?</span>\r\n                </td>\r\n                <td>\r\n                    <span id=\"Main_CustomerEditStats_rpAnswers_lblAnswer_17\" style=\"display:inline-block;font-weight:bold;width:300px;white-space:normal\">Distributor (ADN – Advanced Digital Network Distribution GmbH)</span>\r\n                </td>\r\n            </tr>\r\n        \r\n            <tr>\r\n                <td class=\"s\">\r\n                    <span id=\"Main_CustomerEditStats_rpAnswers_lblQuestion_18\" style=\"display:inline-block;width:300px;white-space:normal\">Does your current distributor offer you 3CX support?</span>\r\n                </td>\r\n                <td>\r\n                    <span id=\"Main_CustomerEditStats_rpAnswers_lblAnswer_18\" style=\"display:inline-block;font-weight:bold;width:300px;white-space:normal\">Yes, I receive both</span>\r\n                </td>\r\n            </tr>\r\n        \r\n            <tr>\r\n                <td class=\"s\">\r\n                    <span id=\"Main_CustomerEditStats_rpAnswers_lblQuestion_19\" style=\"display:inline-block;width:300px;white-space:normal\">How do you rate the service you receive from Technical Support?</span>\r\n                </td>\r\n                <td>\r\n                    <span id=\"Main_CustomerEditStats_rpAnswers_lblAnswer_19\" style=\"display:inline-block;font-weight:bold;width:300px;white-space:normal\">Neutral</span>\r\n                </td>\r\n            </tr>\r\n        \r\n            <tr>\r\n                <td class=\"s\">\r\n                    <span id=\"Main_CustomerEditStats_rpAnswers_lblQuestion_20\" style=\"display:inline-block;width:300px;white-space:normal\">What would enable you to sell more 3CX?</span>\r\n                </td>\r\n                <td>\r\n                    <span id=\"Main_CustomerEditStats_rpAnswers_lblAnswer_20\" style=\"display:inline-block;font-weight:bold;width:300px;white-space:normal\">Other (...)</span>\r\n                </td>\r\n            </tr>\r\n        \r\n            <tr>\r\n                <td class=\"s\">\r\n                    <span id=\"Main_CustomerEditStats_rpAnswers_lblQuestion_21\" style=\"display:inline-block;width:300px;white-space:normal\">What prevents you from closing a sale?</span>\r\n                </td>\r\n                <td>\r\n                    <span id=\"Main_CustomerEditStats_rpAnswers_lblAnswer_21\" style=\"display:inline-block;font-weight:bold;width:300px;white-space:normal\">Customer doesn’t want to invest in new equipment</span>\r\n                </td>\r\n            </tr>\r\n        \r\n            <tr>\r\n                <td class=\"s\">\r\n                    <span id=\"Main_CustomerEditStats_rpAnswers_lblQuestion_22\" style=\"display:inline-block;width:300px;white-space:normal\">Why do you struggle to compete against the providers you selected above? [multiple choice limit up to 2 answers]</span>\r\n                </td>\r\n                <td>\r\n                    <span id=\"Main_CustomerEditStats_rpAnswers_lblAnswer_22\" style=\"display:inline-block;font-weight:bold;width:300px;white-space:normal\">PBX doesn&#39;t meet customer needs,PBX doesn&#39;t integrate with required applications</span>\r\n                </td>\r\n            </tr>\r\n        \r\n            <tr>\r\n                <td class=\"s\">\r\n                    <span id=\"Main_CustomerEditStats_rpAnswers_lblQuestion_23\" style=\"display:inline-block;width:300px;white-space:normal\">Which providers do you find it hardest to compete with?</span>\r\n                </td>\r\n                <td>\r\n                    <span id=\"Main_CustomerEditStats_rpAnswers_lblAnswer_23\" style=\"display:inline-block;font-weight:bold;width:300px;white-space:normal\">Microsoft Teams,Swyx</span>\r\n                </td>\r\n            </tr>\r\n        \r\n    <tr>\r\n        <td class=\"s\" style=\"vertical-align: top\">Notes</td>\r\n        <td>\r\n            <textarea name=\"ctl00$Main$CustomerEditStats$tbNotes\" rows=\"5\" cols=\"20\" id=\"Main_CustomerEditStats_tbNotes\" style=\"width:300px;\">\r\n</textarea></td>\r\n    </tr>\r\n</table>\r\n\r\n                    \r\n\t</div>\r\n\r\n                    <div style=\"clear: both\"></div>\r\n                    \r\n                    <br />\r\n                \r\n</div>\r\n\r\n                <div class=\"buttons\">\r\n                    <input type=\"submit\" name=\"ctl00$Main$btnSaveExit\" value=\"OK\" onclick=\"return true;WebForm_DoPostBackWithOptions(new WebForm_PostBackOptions(&quot;ctl00$Main$btnSaveExit&quot;, &quot;&quot;, true, &quot;&quot;, &quot;&qu