node_modules/
jspm_packages/
web_modules/

# ONYX runtime snapshots (per-rep ERP data, written by /api/ingest/erp)
data/snapshots/

# ONYX encrypted secrets store (contains AES-256-GCM-encrypted API keys)
data/secrets.json
data/secrets.json.tmp

# Browser network recordings — NEVER commit these. They contain session
# cookies, auth headers, and response bodies from staff.3cx.com.
*.har

