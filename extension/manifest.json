{
  "manifest_version": 3,
  "name": "ONYX Bridge",
  "version": "2.2.0",
  "description": "Browser bridge into the ONYX AI Sales Force Assistant. Inbound caller-id partner match on team.3cx.com, Gmail email-to-chat, partner notes dual-written to the staff.3cx.com ERP and ONYX, and on-demand per-partner ERP detail-fetch from the ONYX dashboard.",
  "permissions": ["activeTab", "scripting", "storage", "cookies", "alarms"],
  "host_permissions": [
    "https://mail.google.com/*",
    "https://team.3cx.com/*",
    "https://staff.3cx.com/*",
    "http://localhost/*",
    "https://*.onrender.com/*"
  ],
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://team.3cx.com/*"],
      "js": ["webclient.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["http://localhost/*", "https://*.onrender.com/*"],
      "js": ["bridge.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "unified.html",
    "default_title": "Open ONYX"
  }
}
