{
  "manifest_version": 3,
  "name": "ONYX Bridge",
  "version": "2.0.0",
  "description": "Thin browser bridge into the ONYX AI Sales Force Assistant. Opens partner-aware deep links into the ONYX dashboard from Gmail.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "https://mail.google.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Open ONYX"
  }
}
